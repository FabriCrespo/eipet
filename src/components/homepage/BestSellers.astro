---
---

<!-- Los Más Vendidos -->
<section class="py-6 sm:py-10 lg:py-14 relative overflow-hidden">
  <!-- Background animado sutil -->
  <div class="absolute inset-0 bg-linear-to-br from-gray-50 via-purple-50/30 to-gray-50/50"></div>
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <!-- Círculos animados de fondo -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-[#5d3fbb]/5 rounded-full blur-3xl animate-pulse-slow"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[#ffff11]/5 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/2 left-1/2 w-72 h-72 bg-purple-200/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl relative z-10">
    <!-- Título -->
    <div class="text-center mb-6 sm:mb-8 lg:mb-10">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-gray-900 mb-2 sm:mb-3">
        <span class="bg-linear-to-r from-[#5d3fbb] to-[#6d4fcc] bg-clip-text text-transparent">
          Productos Recién Agregados
        </span>
      </h2>
      <p class="text-gray-600 text-sm sm:text-base max-w-xl mx-auto leading-relaxed px-1">
        Descubre las últimas novedades para tu mascota
      </p>
    </div>

    <!-- Loading state -->
    <div id="bestsellers-loading" class="text-center py-10 sm:py-12">
      <div class="inline-flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-full border-2 border-[#5d3fbb]/20 border-t-[#5d3fbb] animate-spin" aria-hidden="true"></div>
      <p class="mt-3 sm:mt-4 text-sm sm:text-base text-gray-600">Cargando productos recién agregados...</p>
    </div>

    <!-- Empty state -->
    <div id="bestsellers-empty" class="hidden text-center py-10 sm:py-12">
      <svg class="w-14 h-14 sm:w-16 sm:h-16 text-gray-400 mx-auto mb-3 sm:mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
      </svg>
      <p class="text-gray-900 font-semibold mb-2">No hay productos nuevos aún</p>
      <p class="text-gray-500 text-sm">Los productos recién agregados aparecerán aquí</p>
    </div>

    <!-- Carrusel de productos -->
    <div id="bestsellers-carousel" class="hidden">
      <div
        class="relative bestsellers-shell rounded-2xl border border-gray-200/70 bg-white/75 shadow-sm sm:shadow-md backdrop-blur-md py-3 sm:py-4 pl-2 pr-2 sm:pl-3 sm:pr-11 md:pl-4 md:pr-12 lg:px-5"
      >
        <div
          class="pointer-events-none absolute inset-y-2 sm:inset-y-3 left-0 z-10 w-10 sm:w-12 md:w-16 bg-linear-to-r from-white via-white/90 to-transparent rounded-l-2xl"
        ></div>
        <div
          class="pointer-events-none absolute inset-y-2 sm:inset-y-3 right-0 z-10 w-10 sm:w-12 md:w-16 bg-linear-to-l from-white via-white/90 to-transparent rounded-r-2xl"
        ></div>
        <button
          id="bestsellers-prev"
          type="button"
          class="hidden sm:inline-flex absolute left-1 md:left-2 top-1/2 -translate-y-1/2 z-20 h-9 w-9 md:h-11 md:w-11 items-center justify-center rounded-full bg-white text-[#5d3fbb] shadow-md ring-1 ring-gray-200/80 hover:bg-linear-to-br hover:from-white hover:to-purple-50/50 hover:shadow-lg hover:ring-[#5d3fbb]/25 transition-all active:scale-95"
          aria-label="Ver anteriores"
        >
          <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          id="bestsellers-next"
          type="button"
          class="hidden sm:inline-flex absolute right-1 md:right-2 top-1/2 -translate-y-1/2 z-20 h-9 w-9 md:h-11 md:w-11 items-center justify-center rounded-full bg-white text-[#5d3fbb] shadow-md ring-1 ring-gray-200/80 hover:bg-linear-to-br hover:from-white hover:to-purple-50/50 hover:shadow-lg hover:ring-[#5d3fbb]/25 transition-all active:scale-95"
          aria-label="Ver siguientes"
        >
          <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
        <div
          id="bestsellers-track"
          class="bestsellers-scroll flex gap-3 sm:gap-4 md:gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-1 pt-0.5 px-1 sm:px-2 scroll-px-3 sm:scroll-px-4"
          style="scroll-padding-inline: 0.75rem;"
          aria-label="Productos recién agregados"
        >
          <!-- Las cards se renderizan dinámicamente -->
        </div>
      </div>
      <div id="bestsellers-dots" class="mt-4 sm:mt-5 flex flex-wrap items-center justify-center gap-2 sm:gap-2.5 px-2"></div>
    </div>

    <!-- CTA para ver todos los productos -->
    <div class="mt-7 sm:mt-9 lg:mt-11 text-center animate-fade-in-up" style="animation-delay: 0.6s;">
      <a 
        href="/products" 
        class="inline-flex items-center gap-2 sm:gap-3 bg-linear-to-r from-[#5d3fbb] to-[#6d4fcc] hover:from-[#6d4fcc] hover:to-[#7d5fdd] text-white font-bold text-sm sm:text-base px-5 sm:px-8 py-3 sm:py-3.5 rounded-xl sm:rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:scale-[1.02] active:scale-95"
        data-astro-prefetch
      >
        <span>Ver todos los productos</span>
        <svg class="w-5 h-5 sm:w-6 sm:h-6 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>

<script>
  import { scheduleNavigationLoader } from '../../lib/ui/navigationLoader';

  (async function() {
    // Funciones helper para formatear números
    function formatCurrency(value: number): string {
      return value.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    function escapeAttr(value: string): string {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/"/g, '&quot;')
        .replace(/</g, '&lt;');
    }

    /** Catálogo en la vista de la marca del producto (sin exponer id en /product). */
    function buildProductsBrandUrl(p: any): string {
      const bid = p.brand != null && String(p.brand).trim() !== '' ? String(p.brand).trim() : '';
      const cid = p.category != null && String(p.category).trim() !== '' ? String(p.category).trim() : '';
      if (!bid) return '/products';
      const q = new URLSearchParams();
      q.set('brand', bid);
      if (cid) q.set('category', cid);
      return `/products?${q.toString()}`;
    }

    function getTrackGapPx(track: HTMLElement): number {
      const raw = getComputedStyle(track).columnGap || getComputedStyle(track).gap;
      const n = parseFloat(raw);
      return Number.isFinite(n) && n > 0 ? n : 16;
    }

    // Elementos del DOM
    const bestsellersLoading = document.getElementById('bestsellers-loading');
    const bestsellersEmpty = document.getElementById('bestsellers-empty');
    const bestsellersCarousel = document.getElementById('bestsellers-carousel');
    const bestsellersTrack = document.getElementById('bestsellers-track') as HTMLDivElement | null;
    const bestsellersPrev = document.getElementById('bestsellers-prev') as HTMLButtonElement | null;
    const bestsellersNext = document.getElementById('bestsellers-next') as HTMLButtonElement | null;
    const bestsellersDots = document.getElementById('bestsellers-dots');

    let autoPlayTimer: ReturnType<typeof setInterval> | null = null;
    let scrollRaf = 0;
    let activeDotIndex = 0;
    let carouselCards: HTMLElement[] = [];
    let dotButtons: HTMLButtonElement[] = [];
    let trackClickAbort: AbortController | null = null;

    function stopAutoPlay() {
      if (autoPlayTimer) {
        clearInterval(autoPlayTimer);
        autoPlayTimer = null;
      }
    }

    const DOT_BTN_BASE =
      'h-2 sm:h-2.5 rounded-full transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#5d3fbb]/40 focus-visible:ring-offset-2';

    function dotButtonClass(isActive: boolean): string {
      if (isActive) {
        return `${DOT_BTN_BASE} w-7 sm:w-8 bg-linear-to-r from-[#5d3fbb] to-[#6d4fcc] shadow-sm`;
      }
      return `${DOT_BTN_BASE} w-2 sm:w-2.5 bg-gray-300 hover:bg-gray-400`;
    }

    function setActiveDot(index: number) {
      if (!dotButtons.length) return;
      const nextIdx = Math.max(0, Math.min(index, dotButtons.length - 1));
      if (nextIdx === activeDotIndex) return;
      activeDotIndex = nextIdx;
      dotButtons.forEach((btn, i) => {
        btn.className = dotButtonClass(i === activeDotIndex);
      });
    }

    function startAutoPlay() {
      if (!bestsellersTrack || document.hidden || carouselCards.length <= 1) return;
      stopAutoPlay();
      autoPlayTimer = setInterval(() => {
        if (document.hidden) return;
        const first = carouselCards[0];
        if (!first) return;
        const gapPx = getTrackGapPx(bestsellersTrack);
        const cardWidth = first.offsetWidth + gapPx;
        const maxScroll = bestsellersTrack.scrollWidth - bestsellersTrack.clientWidth - 4;
        const nextLeft = bestsellersTrack.scrollLeft + cardWidth;
        bestsellersTrack.scrollTo({
          left: nextLeft > maxScroll ? 0 : nextLeft,
          behavior: 'smooth'
        });
      }, 5000);
    }

    function updateDots() {
      if (!bestsellersTrack || !dotButtons.length || !carouselCards.length) return;
      const currentIndex = carouselCards.findIndex((card) => {
        const cardLeft = card.offsetLeft - bestsellersTrack.scrollLeft;
        return cardLeft >= -card.offsetWidth * 0.35 && cardLeft < card.offsetWidth * 0.65;
      });
      setActiveDot(currentIndex >= 0 ? currentIndex : 0);
    }

    function setupCarousel() {
      if (!bestsellersTrack || !bestsellersDots) return;
      if (trackClickAbort) {
        trackClickAbort.abort();
        trackClickAbort = null;
      }
      carouselCards = Array.from(bestsellersTrack.querySelectorAll('.bestseller-slide')) as HTMLElement[];
      if (!carouselCards.length) return;

      bestsellersDots.innerHTML = carouselCards
        .map((_card: HTMLElement, index: number) => {
          return `
          <button
            type="button"
            class="${dotButtonClass(index === 0)}"
            data-dot-index="${index}"
            aria-label="Ir al producto ${index + 1}"
          ></button>
        `;
        })
        .join('');

      dotButtons = Array.from(bestsellersDots.querySelectorAll('button')) as HTMLButtonElement[];
      activeDotIndex = 0;

      dotButtons.forEach((dot) => {
        dot.addEventListener('click', () => {
          const index = Number((dot as HTMLElement).getAttribute('data-dot-index') || 0);
          const target = carouselCards[index];
          if (!target) return;
          bestsellersTrack.scrollTo({ left: target.offsetLeft, behavior: 'smooth' });
          setActiveDot(index);
        });
      });

      bestsellersPrev?.addEventListener('click', () => {
        const first = carouselCards[0];
        const gapPx = getTrackGapPx(bestsellersTrack);
        const cardWidth = first ? first.offsetWidth + gapPx : 280;
        bestsellersTrack.scrollBy({ left: -cardWidth, behavior: 'smooth' });
      });

      bestsellersNext?.addEventListener('click', () => {
        const first = carouselCards[0];
        const gapPx = getTrackGapPx(bestsellersTrack);
        const cardWidth = first ? first.offsetWidth + gapPx : 280;
        bestsellersTrack.scrollBy({ left: cardWidth, behavior: 'smooth' });
      });

      trackClickAbort = new AbortController();
      bestsellersTrack.addEventListener(
        'click',
        (e) => {
          const a = (e.target as HTMLElement).closest('a.bestseller-slide') as HTMLAnchorElement | null;
          if (!a?.href?.includes('/products')) return;
          scheduleNavigationLoader();
        },
        { signal: trackClickAbort.signal }
      );

      bestsellersTrack.addEventListener('scroll', () => {
        if (scrollRaf) return;
        scrollRaf = window.requestAnimationFrame(() => {
          updateDots();
          scrollRaf = 0;
        });
      }, { passive: true });
      bestsellersTrack.addEventListener('mouseenter', stopAutoPlay);
      bestsellersTrack.addEventListener('mouseleave', startAutoPlay);
      bestsellersTrack.addEventListener('touchstart', stopAutoPlay, { passive: true });
      bestsellersTrack.addEventListener('touchend', startAutoPlay, { passive: true });

      setActiveDot(0);
      startAutoPlay();
    }

    // Función para convertir Timestamp de Firestore a Date
    function toDate(value: any): Date | null {
      if (!value) return null;
      if (value instanceof Date) return value;
      if (value && typeof value === 'object' && 'toDate' in value && typeof value.toDate === 'function') {
        return value.toDate();
      }
      if (typeof value === 'string' || typeof value === 'number') {
        return new Date(value);
      }
      return null;
    }

    function getLatestProducts(source: any[], minCount = 5, maxCount = 10) {
      const sorted = [...source].sort((a: any, b: any) => {
        const dateA = toDate(a.createdAt) || toDate(a.updatedAt);
        const dateB = toDate(b.createdAt) || toDate(b.updatedAt);

        if (!dateA && !dateB) return 0;
        if (!dateA) return 1;
        if (!dateB) return -1;

        return dateB.getTime() - dateA.getTime();
      });

      if (sorted.length <= maxCount) return sorted;
      return sorted.slice(0, Math.max(minCount, Math.min(maxCount, sorted.length)));
    }

    // Función para cargar productos recién agregados
    async function loadBestSellers() {
      try {
        const { getProducts } = await import('../../lib/db/products');

        // Primer intento: activos
        const activeResult = await getProducts({ status: 'active' });
        let allProducts = activeResult.data || [];

        // Fallback: si no trajo nada (índice/permisos/filtro), traer todos y filtrar en cliente
        if (allProducts.length === 0) {
          const fallbackResult = await getProducts();
          const fallbackProducts = fallbackResult.data || [];
          const activeOnly = fallbackProducts.filter((p: any) => !p?.status || p.status === 'active');
          allProducts = activeOnly.length > 0 ? activeOnly : fallbackProducts;
        }

        const sortedProducts = getLatestProducts(allProducts, 5, 10);
        
        // Ocultar loading
        if (bestsellersLoading) bestsellersLoading.classList.add('hidden');
        
        if (sortedProducts.length === 0) {
          if (bestsellersEmpty) bestsellersEmpty.classList.remove('hidden');
          if (bestsellersCarousel) bestsellersCarousel.classList.add('hidden');
          return;
        }
        
        if (bestsellersEmpty) bestsellersEmpty.classList.add('hidden');
        if (bestsellersCarousel && bestsellersTrack) {
          bestsellersCarousel.classList.remove('hidden');

          // Tarjetas → catálogo por marca (URL sin página de detalle con id)
          bestsellersTrack.innerHTML = sortedProducts.map((product: any, index: number) => {
            const isNew = index === 0;
            const hasDiscount = product.discount > 0;
            const badge = isNew ? 'Nuevo' : (hasDiscount ? `-${Math.round(product.discount)}%` : '');
            const badgeClass = isNew ? 'bg-[#ffff11] text-[#5d3fbb]' : 'bg-red-500 text-white';
            const brandText = product.brandName || 'Sin marca';
            const nameText = String(product.name || '').trim() || 'Producto';
            const safeImage = product.image || 'https://images.unsplash.com/photo-1551717743-49959800b1f6?w=400&q=80';
            const catalogUrl = buildProductsBrandUrl(product);
            const cardAria = `Abrir en catálogo: ${nameText}. Marca ${brandText}.`;

            return `
              <a
                href="${catalogUrl}"
                class="bestseller-slide product-card group snap-start shrink-0 w-[84vw] max-w-[300px] sm:w-[46%] sm:max-w-none md:w-[31%] lg:w-[24%] xl:w-[20%] bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-gray-100/90 hover:border-[#5d3fbb]/30 flex flex-col animate-fade-in-up ring-1 ring-black/[0.03] hover:ring-[#5d3fbb]/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#5d3fbb]/35 focus-visible:ring-offset-2"
                style="animation-delay: ${(index + 1) * 0.08}s;"
                data-astro-prefetch
                aria-label="${escapeAttr(cardAria)}"
              >
                <div class="relative aspect-[4/3] sm:h-44 md:h-48 lg:h-52 max-h-[13rem] sm:max-h-none bg-linear-to-b from-gray-50 to-gray-100/80 overflow-hidden shrink-0 flex items-center justify-center p-3 sm:p-4">
                  ${badge ? `
                    <div class="absolute top-2 left-2 z-10 ${badgeClass} px-2 py-0.5 sm:py-1 rounded-md text-[10px] sm:text-xs font-bold shadow-md">
                      ${badge}
                    </div>
                  ` : ''}
                  ${product.weight ? `
                    <div class="absolute bottom-2 left-2 z-10 bg-[#5d3fbb] text-white px-2 py-0.5 sm:py-1 rounded-md text-[10px] sm:text-xs font-bold shadow-md">
                      ${product.weight}
                    </div>
                  ` : ''}
                  <img
                    src="${safeImage}"
                    alt="${escapeAttr(nameText)}"
                    class="max-w-full max-h-full w-auto h-auto object-contain group-hover:scale-[1.04] transition-transform duration-500"
                    loading="lazy"
                    decoding="async"
                    onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1551717743-49959800b1f6?w=400&q=80';"
                  />
                </div>
                <div class="p-3 sm:p-4 bg-linear-to-b from-white to-purple-50/40 flex flex-col grow min-h-0">
                  <p class="text-[11px] sm:text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1 line-clamp-1">${brandText}</p>
                  <h3 class="font-bold text-sm sm:text-base text-gray-800 mb-1.5 sm:mb-2 line-clamp-2 min-h-[2.5rem] sm:min-h-10 leading-snug">${product.name}</h3>
                  <p class="text-[11px] sm:text-xs text-[#5d3fbb]/80 font-medium mt-auto pt-1">Ver en catálogo →</p>
                  <div class="flex items-end gap-2 flex-wrap pt-1">
                    <p class="text-base sm:text-lg md:text-xl font-bold text-[#5d3fbb] tabular-nums">Bs. ${formatCurrency(product.price || 0)}</p>
                    ${hasDiscount && product.originalPrice ? `
                      <p class="text-xs sm:text-sm text-gray-400 line-through pb-0.5">Bs. ${formatCurrency(product.originalPrice)}</p>
                    ` : ''}
                  </div>
                </div>
              </a>
            `;
          }).join('');

          setupCarousel();
        }
        
      } catch (error) {
        console.error('Error cargando productos recién agregados:', error);
        if (bestsellersLoading) bestsellersLoading.classList.add('hidden');
        if (bestsellersEmpty) {
          bestsellersEmpty.classList.remove('hidden');
          const errorMsg = bestsellersEmpty.querySelector('p');
          if (errorMsg) errorMsg.textContent = 'Error al cargar los productos recién agregados';
        }
      }
    }

    // Cargar productos al iniciar
    await loadBestSellers();

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAutoPlay();
      } else {
        startAutoPlay();
      }
    });

    window.addEventListener('beforeunload', () => stopAutoPlay());
  })();
</script>

<style>
  /* Animación de entrada */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.6s ease-out both;
  }

  /* Animación de pulso lento para el background */
  @keyframes pulse-slow {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.1);
    }
  }

  .animate-pulse-slow {
    animation: pulse-slow 8s ease-in-out infinite;
  }

  .bestsellers-scroll {
    scrollbar-width: none;
    -ms-overflow-style: none;
    overscroll-behavior-x: contain;
  }

  .bestsellers-scroll::-webkit-scrollbar {
    display: none;
  }

  /* Efectos hover mejorados */
  .product-card {
    transform: translateZ(0);
    backface-visibility: hidden;
  }

  .product-card:hover {
    transform: translateY(-6px) scale(1.02);
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up,
    .animate-pulse-slow,
    .product-card,
    .bestsellers-scroll {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }
  }

  /* Line clamp */
  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
