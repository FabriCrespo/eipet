---
// Sección de categorías (Categoría → Marca → Productos).
// El script inyecta las cards en #categories-grid y controla visibilidad de #categories-section.
---

<section id="categories-section" class="mb-4 sm:mb-8 hidden" aria-label="Elige una categoría">
  <div class="mb-2 sm:mb-4 flex items-center justify-between">
    <a href="/" class="text-sm text-[#5d3fbb] hover:text-[#6d4fcc] hover:underline font-medium" aria-label="Volver al inicio">← Inicio</a>
    <h2 class="text-base sm:text-xl lg:text-2xl font-bold text-gray-900">Elige una categoría</h2>
    <span class="w-14 sm:w-16" aria-hidden="true"></span>
  </div>
  <div
    id="categories-grid"
    class="grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-3 gap-1.5 sm:gap-4 lg:gap-6"
    role="list"
  >
    <!-- Las categorías se renderizan aquí por el script de la página -->
  </div>
</section>
