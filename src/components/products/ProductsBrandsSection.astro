---
// Sección de marcas: paso 2 del flujo (Categoría → Marca → Productos).
// El script inyecta las cards en #brands-grid y controla visibilidad de #brands-section.
---

<section id="brands-section" class="mb-8 hidden" aria-label="Elige una marca">
  <div class="mb-6">
    <h2 class="text-xl sm:text-2xl font-bold text-gray-900">Elige una marca</h2>
  </div>
  <div
    id="brands-grid"
    class="grid grid-cols-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4 lg:gap-6"
    role="list"
  >
    <!-- Las marcas se renderizan aquí por el script de la página -->
  </div>
</section>
