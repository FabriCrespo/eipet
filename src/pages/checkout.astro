      /** Coloca el pin en el mapa móvil y actualiza lat/lng + geocodificación (como la web) */
      function placeMobileMarkerAt(lat: number, lng: number) {
        const L = (window as any).L;
        if (!mobileMap || !L) return;
        if (mobileMarker) mobileMarker.setLatLng([lat, lng]);
        else {
