      async function reverseGeocode(lat: number, lng: number, forMobile = false) {
        const statusEl = forMobile ? document.getElementById('mobile-map-status') : mapStatus;
        if (statusEl) statusEl.textContent = 'Obteniendo dirección...';
        if (!forMobile && mapStatus) setMapStatus('Obteniendo dirección...');
        try {
          const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&zoom=18&addressdetails=1`;
          const res = await fetch(url, { headers: { 'Accept-Language': 'es' } });
          const data = await res.json();
          const a = data.address || {};
          const fullAddress = [a.road, a.house_number, a.suburb, a.neighbourhood].filter(Boolean).join(', ') || data.display_name || '';
          const city = a.city || a.town || a.village || a.municipality || a.state || '';
          const district = a.suburb || a.neighbourhood || a.quarter || a.district || '';
          if (forMobile) {
            const addrInput = document.getElementById('mobile-address') as HTMLInputElement;
            const cityInput = document.getElementById('mobile-city') as HTMLInputElement;
            const distInput = document.getElementById('mobile-district') as HTMLInputElement;
            if (addrInput) addrInput.value = fullAddress || `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            if (cityInput) cityInput.value = city;
            if (distInput) distInput.value = district;
            if (mobileDeliveryAddress) mobileDeliveryAddress.textContent = fullAddress || `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            if (statusEl) statusEl.textContent = 'Dirección actualizada. Puedes editar los campos si hace falta.';
          } else {
            const addressInput = document.getElementById('address') as HTMLInputElement;
            const cityInput = document.getElementById('city') as HTMLInputElement;
            const districtInput = document.getElementById('district') as HTMLInputElement;
            if (addressInput) addressInput.value = fullAddress || `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            if (cityInput) cityInput.value = city;
            if (districtInput) districtInput.value = district;
            setMapStatus('Dirección actualizada. Puedes editar los campos si hace falta.');
          }
        } catch (e) {
          if (forMobile) {
            const addrInput = document.getElementById('mobile-address') as HTMLInputElement;
            if (addrInput) addrInput.value = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
            if (statusEl) statusEl.textContent = 'No se pudo obtener la dirección. Completa los campos manualmente.';
          } else {
            setMapStatus('No se pudo obtener la dirección. Completa los campos manualmente.', true);
            const addressInput = document.getElementById('address') as HTMLInputElement;
            if (addressInput) addressInput.value = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;
          }
        }
      }

      function updateMarkerPosition(lat: number, lng: number) {
        if (addressLatInput) addressLatInput.value = String(lat);
        if (addressLngInput) addressLngInput.value = String(lng);
        reverseGeocode(lat, lng);
      }

      function updateMobileMarkerPosition(lat: number, lng: number) {
        if (addressLatInput) addressLatInput.value = String(lat);
        if (addressLngInput) addressLngInput.value = String(lng);
        reverseGeocode(lat, lng, true);
        saveGuestShippingDraft();
      }

      function initCheckoutMap() {
        if (!checkoutMapDiv || checkoutMap) return;
        const L = (window as any).L;
        if (!L) {
          setMapStatus('Cargando mapa...');
          setTimeout(initCheckoutMap, 300);
          return;
        }
        checkoutMap = L.map('checkout-map').setView(DEFAULT_CENTER, DEFAULT_ZOOM);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© OpenStreetMap'
        }).addTo(checkoutMap);
        checkoutMap.on('click', (e: any) => {
          const { lat, lng } = e.latlng;
          if (checkoutMarker) checkoutMarker.setLatLng([lat, lng]);
          else {
            checkoutMarker = L.marker([lat, lng], { draggable: true }).addTo(checkoutMap);
            checkoutMarker.on('dragend', () => {
              const pos = checkoutMarker.getLatLng();
              updateMarkerPosition(pos.lat, pos.lng);
            });
          }
          updateMarkerPosition(lat, lng);
        });
        setTimeout(() => checkoutMap.invalidateSize(), 200);
        setMapStatus('Haz clic en el mapa o usa "Usar mi ubicación actual" para marcar el punto de entrega.');
      }

      function initMobileMap() {
        const mobileMapDiv = document.getElementById('checkout-mobile-map');
        if (!mobileMapDiv || mobileMap) return;
        const L = (window as any).L;
        if (!L) {
          setTimeout(initMobileMap, 300);
          return;
        }
        mobileMap = L.map('checkout-mobile-map').setView(DEFAULT_CENTER, DEFAULT_ZOOM);
