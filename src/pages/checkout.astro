      function addEipetStoreMarker(map: any, L: any) {
        if (!map || !L) return;
        /* Icono de casa (Material); se lee bien en mapa y distingue del pin azul de entrega */
        const storeSvg =
          '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="22" height="22" aria-hidden="true" focusable="false">' +
          '<path fill="#5d3fbb" d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>' +
          '</svg>';
        const icon = L.divIcon({
          className: 'eipet-store-map-marker',
          html:
            '<div class="eipet-store-map-marker__pin" aria-hidden="true">' +
            '<div class="eipet-store-map-marker__bubble">' +
            storeSvg +
            '</div>' +
            '<div class="eipet-store-map-marker__tail"></div>' +
            '</div>',
          iconSize: [40, 46],
          iconAnchor: [20, 46],
          popupAnchor: [0, -42],
        });
        L.marker(STORE_EIPET_LAT_LNG, { icon, interactive: true, zIndexOffset: 150 })
          .bindPopup(
            '<strong>Tienda Eipet</strong><br><small style="opacity:0.85;font-size:11px">Recogida en tienda</small>'
          )
          .addTo(map);
      }

      /** Encuadra tienda + punto de entrega (si están lejos, aleja zoom para ver ambos). */
      function fitMapToStoreAndDelivery(map: any, L: any, deliveryLat: number, deliveryLng: number) {
        if (!map || !L || typeof deliveryLat !== 'number' || typeof deliveryLng !== 'number') return;
        if (isNaN(deliveryLat) || isNaN(deliveryLng)) return;
        const bounds = L.latLngBounds([STORE_EIPET_LAT_LNG, [deliveryLat, deliveryLng]]);
        map.fitBounds(bounds, { padding: [44, 44], maxZoom: 16, animate: true });
        setTimeout(() => map.invalidateSize(), 350);
      }

