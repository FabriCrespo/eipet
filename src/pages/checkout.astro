      function setShippingHints(text: string, kind: 'success' | 'warning' | 'info' | 'neutral') {
        const base = 'checkout-shipping-hint text-xs leading-snug rounded-lg px-2 py-1.5 border mt-1';
        const cls =
          kind === 'success'
            ? `${base} bg-green-50 border-green-100 text-green-800`
            : kind === 'warning'
              ? `${base} bg-amber-50 border-amber-100 text-amber-900`
              : kind === 'info'
                ? `${base} bg-blue-50 border-blue-100 text-blue-900`
                : `${base} bg-gray-50 border-gray-100 text-gray-700`;
        ['shipping-hint-desktop', 'shipping-hint-mobile-step1', 'shipping-hint-mobile-step2'].forEach((id) => {
          const el = document.getElementById(id);
          if (!el) return;
          if (!text) {
            el.textContent = '';
            el.className = `${base} hidden`;
            return;
          }
          el.textContent = text;
          el.className = cls;
        });
      }

      function computeCartSubtotal(): number {
        let sub = 0;
        cartItems.forEach((item) => {
          const product = productsData.get(item.productId);
          if (product) sub += (product.price || 0) * (item.quantity || 1);
        });
        return sub;
      }

      function recalculateShipping() {
        const subtotal = computeCartSubtotal();
        const min = deliverySettings.minPurchaseAmount ?? 200;
        const km = deliverySettings.coverageRadiusKm ?? 5;
        const enabled = deliverySettings.freeDeliveryEnabled !== false;
        const msgTe = deliverySettings.messageTeFaltan || DEFAULT_DELIVERY_CLIENT.messageTeFaltan;
        const msgFuera = deliverySettings.messageFueraCobertura || DEFAULT_DELIVERY_CLIENT.messageFueraCobertura;
        const msgGratis = deliverySettings.messageEnvioGratis || DEFAULT_DELIVERY_CLIENT.messageEnvioGratis;

        lastOutOfCoverage = false;
        lastFreeDeliveryPromo = false;

        if (deliveryType === 'recoger') {
          shippingCost = 0;
          setCheckoutEnvioGratisBanner(false, '');
          setShippingHints('Recoges en tienda — sin costo de envío a domicilio.', 'neutral');
          return;
        }

        if (!enabled) {
          shippingCost = PAID_SHIPPING_FALLBACK_BS;
          setCheckoutEnvioGratisBanner(false, '');
          setShippingHints('El envío gratis no está habilitado en este momento.', 'neutral');
          return;
        }

        const lat = parseFloat(String(addressLatInput?.value || '').trim());
        const lng = parseFloat(String(addressLngInput?.value || '').trim());
        const hasCoords = !isNaN(lat) && !isNaN(lng) && !(lat === 0 && lng === 0);

        if (!hasCoords) {
          shippingCost = PAID_SHIPPING_FALLBACK_BS;
          setCheckoutEnvioGratisBanner(false, '');
          setShippingHints('Marca tu ubicación en el mapa para calcular si aplica envío gratis.', 'info');
          return;
        }

        const dist = haversineKm(STORE_EIPET_LAT_LNG[0], STORE_EIPET_LAT_LNG[1], lat, lng);
        if (dist > km) {
          shippingCost = PAID_SHIPPING_FALLBACK_BS;
          lastOutOfCoverage = true;
          setCheckoutEnvioGratisBanner(false, '');
          setShippingHints(msgFuera, 'warning');
          return;
        }

        if (subtotal >= min) {
          shippingCost = 0;
          lastFreeDeliveryPromo = true;
          setCheckoutEnvioGratisBanner(true, msgGratis);
          setShippingHints('Envío a domicilio sin costo en esta zona.', 'success');
          return;
        }

        shippingCost = PAID_SHIPPING_FALLBACK_BS;
        const falta = Math.max(0, min - subtotal);
        const amt = formatPrice(falta);
        const teFaltanText = msgTe.replace(/\{amount\}/g, amt);
        userSawTeFaltanMessage = true;
        setCheckoutEnvioGratisBanner(false, '');
        setShippingHints(teFaltanText, 'info');
      }

