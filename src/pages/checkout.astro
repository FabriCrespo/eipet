  <script>
    (async () => {
      // Verificar autenticación (solo requerida al confirmar, no para ver el checkout)
      const { getCurrentUser, onAuthStateChange } = await import('../lib/auth');
      
      let currentUser: any = null;
      let currentUserId: string | null = null;
      let cartItems: any[] = [];
      let productsData: Map<string, any> = new Map();
      let shippingCost = 0;
      let userAddresses: any[] = [];
      let userPaymentMethods: any[] = [];
      let selectedAddressId: string | null = null;
      let selectedPaymentMethodId: string | null = null;
      let useManualAddress = true;
      let useManualPayment = true;

      // Función para obtener y actualizar el usuario actual
      async function updateCurrentUser() {
        console.log('🔐 [CHECKOUT] updateCurrentUser - Verificando autenticación...');
        const firebaseUser = getCurrentUser();
        console.log('🔐 [CHECKOUT] firebaseUser desde getCurrentUser():', firebaseUser);
        console.log('🔐 [CHECKOUT] auth.currentUser:', (await import('../lib/firebase')).auth.currentUser);
        
        if (firebaseUser) {
          currentUserId = firebaseUser.uid;
          console.log('🔐 [CHECKOUT] Usuario encontrado, currentUserId:', currentUserId);
        } else {
          currentUserId = null;
          console.log('🔐 [CHECKOUT] No se encontró usuario autenticado');
        }
        return currentUserId;
      }

      // Esperar a que Firebase Auth esté inicializado usando onAuthStateChange
      let authInitialized = false;
      const unsubscribeAuth = onAuthStateChange((firebaseUser) => {
        console.log('🔐 [CHECKOUT] onAuthStateChange - Usuario cambió:', firebaseUser);
        if (!authInitialized) {
          authInitialized = true;
          console.log('🔐 [CHECKOUT] Firebase Auth inicializado');
        }
        
        if (firebaseUser) {
          currentUserId = firebaseUser.uid;
          console.log('🔐 [CHECKOUT] Usuario autenticado, currentUserId:', currentUserId);
          // Recargar direcciones y métodos de pago si el usuario se autentica y el checkout está visible
          if (checkoutContent && !checkoutContent.classList.contains('hidden')) {
            console.log('🔐 [CHECKOUT] Checkout visible, cargando direcciones y métodos de pago...');
            loadUserAddresses();
            loadUserPaymentMethods();
          }
        } else {
          currentUserId = null;
          console.log('🔐 [CHECKOUT] Usuario desautenticado');
        }
      });
      
      // Esperar un momento para que Firebase Auth se inicialice
      await new Promise(resolve => setTimeout(resolve, 100));
      
      // Verificar usuario después de esperar
      await updateCurrentUser();

      // Elementos del DOM
      const loadingDiv = document.getElementById('checkout-loading');
      const errorDiv = document.getElementById('checkout-error');
      const errorMessage = document.getElementById('error-message');
      const emptyCartDiv = document.getElementById('empty-cart');
      const checkoutContent = document.getElementById('checkout-content');
      const orderItemsDiv = document.getElementById('order-items');
      const subtotalSpan = document.getElementById('subtotal');
      const shippingCostSpan = document.getElementById('shipping-cost');
      const discountSpan = document.getElementById('discount');
      const discountRow = document.getElementById('discount-row');
      const totalSpan = document.getElementById('total');
      const confirmBtn = document.getElementById('confirm-order-btn');
      const confirmBtnText = document.getElementById('confirm-btn-text');
      const confirmBtnLoading = document.getElementById('confirm-btn-loading');
      const shippingForm = document.getElementById('shipping-form') as HTMLFormElement;
      const savedAddressesSection = document.getElementById('saved-addresses-section');
      const addressesList = document.getElementById('addresses-list');
      const useNewAddressBtn = document.getElementById('use-new-address-btn');
      const savedPaymentMethodsSection = document.getElementById('saved-payment-methods-section');
      const paymentMethodsList = document.getElementById('payment-methods-list');
      const useNewPaymentBtn = document.getElementById('use-new-payment-btn');
      const paymentMethodsOptions = document.getElementById('payment-methods-options');
      const mapAddressSection = document.getElementById('map-address-section');
      const checkoutMapDiv = document.getElementById('checkout-map');
      const useMyLocationBtn = document.getElementById('use-my-location-btn');
      const mapStatus = document.getElementById('map-status');
      const addressLatInput = document.getElementById('address-lat') as HTMLInputElement;
      const addressLngInput = document.getElementById('address-lng') as HTMLInputElement;
      const checkoutDesktop = document.getElementById('checkout-desktop');
      const checkoutMobile = document.getElementById('checkout-mobile');
      const mobileOrderItems = document.getElementById('mobile-order-items');
      const mobileSubtotalEl = document.getElementById('mobile-subtotal');
      const mobileSubtotalCopyEl = document.getElementById('mobile-subtotal-copy');
      const mobileShippingEl = document.getElementById('mobile-shipping');
      const mobileTotalEl = document.getElementById('mobile-total');
      const mobilePedirPagarBtn = document.getElementById('mobile-pedir-pagar-btn');
      const mobileSelectedPaymentLabel = document.getElementById('mobile-selected-payment-label');
      const mobileSelectedPaymentShort = document.getElementById('mobile-selected-payment-short');
      const paymentMethodModal = document.getElementById('payment-method-modal');
      const paymentMethodModalClose = document.getElementById('payment-method-modal-close');
      const checkoutStep1 = document.getElementById('checkout-step-1');
      const checkoutStep2 = document.getElementById('checkout-step-2');
      const mobileMapSection = document.getElementById('mobile-map-section');
      const mobileStep2Products = document.getElementById('mobile-step2-products');
      const mobileStep2Shipping = document.getElementById('mobile-step2-shipping');
      const mobileStep2Subtotal = document.getElementById('mobile-step2-subtotal');
      const mobileDeliveryTypeLabel = document.getElementById('mobile-delivery-type-label');
      const mobileDeliveryAddress = document.getElementById('mobile-delivery-address');
      const mobileDeliveryInstructionsPreview = document.getElementById('mobile-delivery-instructions-preview');
      const mobileBillingName = document.getElementById('mobile-billing-name');
      const mobileBillingNit = document.getElementById('mobile-billing-nit');
      const addressNameInput = document.getElementById('addressName') as HTMLInputElement | null;
      const mobileAddressLabelInput = document.getElementById('mobile-address-label') as HTMLInputElement | null;
      const mobileSaveAddressBtn = document.getElementById('mobile-save-address-btn');
      const mobileGuestAddressesSection = document.getElementById('mobile-guest-addresses-section');
      const mobileGuestAddressesList = document.getElementById('mobile-guest-addresses-list');
      const mobileFullNameInput = document.getElementById('mobile-fullName') as HTMLInputElement | null;
      const mobilePhoneInput = document.getElementById('mobile-phone') as HTMLInputElement | null;
      const mobileAddressInput = document.getElementById('mobile-address') as HTMLInputElement | null;
      const mobileCityInput = document.getElementById('mobile-city') as HTMLInputElement | null;
      const mobileDistrictInput = document.getElementById('mobile-district') as HTMLInputElement | null;
      const mobileInstructionsInput = document.getElementById('mobile-instructions-input') as HTMLTextAreaElement | null;
      const mobileBillingNameInput = document.getElementById('mobile-billing-name-input') as HTMLInputElement | null;
      const mobileBillingNitInput = document.getElementById('mobile-billing-nit-input') as HTMLInputElement | null;

      let deliveryType: 'envio' | 'recoger' = 'envio';
      let currentPaymentMethod: 'cash' | 'qr' | 'card' = 'qr';
      let currentMobileStep: 1 | 2 | 3 = 1;
      let isMobileView = () => typeof window !== 'undefined' && window.innerWidth < 1024;
      const GUEST_SHIPPING_STORAGE_KEY = 'eipet_guest_shipping_v1';
      const GUEST_ADDRESSES_STORAGE_KEY = 'eipet_guest_addresses_v1';
      const GUEST_SELECTED_ADDRESS_KEY = 'eipet_guest_selected_address_v1';

      // Mapa: Leaflet (se usa cuando addressSource === 'map')
      let checkoutMap: any = null;
      let checkoutMarker: any = null;
      let mobileMap: any = null;
      let mobileMarker: any = null;
      const DEFAULT_CENTER: [number, number] = [-16.4897, -68.1193]; // La Paz, Bolivia
      const DEFAULT_ZOOM = 14;

      function setMapStatus(msg: string, isError = false) {
        if (mapStatus) {
          mapStatus.textContent = msg;
          mapStatus.className = 'text-sm mb-2 ' + (isError ? 'text-red-600' : 'text-gray-500');
        }
      }

      function getPaymentLabelAndBadge(method: 'cash' | 'qr' | 'card') {
        if (method === 'cash') return { label: 'Efectivo', badge: 'EF' };
        if (method === 'card') return { label: 'Tarjeta de crédito o débito', badge: 'TC' };
        return { label: 'Codigo QR', badge: 'QR' };
      }

      function syncMobilePaymentSummary(method: 'cash' | 'qr' | 'card' = currentPaymentMethod) {
        const data = getPaymentLabelAndBadge(method);
        if (mobileSelectedPaymentLabel) mobileSelectedPaymentLabel.textContent = data.label;
        if (mobileSelectedPaymentShort) mobileSelectedPaymentShort.textContent = data.badge;
      }

      function resolveAddressTypeLabel(addr: any): string {
        const raw = String(addr?.name || '').trim();
        const normalized = raw.toLowerCase();
        if (!normalized) return 'Dirección';
        if (normalized.includes('trabajo') || normalized.includes('oficina') || normalized.includes('empresa')) return 'Trabajo';
        if (normalized.includes('casa') || normalized.includes('hogar') || normalized.includes('domicilio')) return 'Casa';
        if (raw.length > 24) return `${raw.slice(0, 24)}...`;
        return raw;
      }

      function resolveTypedAddressLabel() {
        const raw = String(mobileAddressLabelInput?.value || '').trim();
        if (!raw) return 'Dirección';
        if (raw.length > 24) return `${raw.slice(0, 24)}...`;
        return raw;
      }

      function updateMobileInstructionsPreview(text?: string) {
        if (!mobileDeliveryInstructionsPreview) return;
        const value = (text ?? mobileInstructionsInput?.value ?? '').trim();
        mobileDeliveryInstructionsPreview.textContent = value || 'Agrega una referencia para el repartidor.';
      }

      function saveGuestShippingDraft() {
        if (currentUserId) return;
        try {
          const desktopFullNameInput = document.getElementById('fullName') as HTMLInputElement | null;
          const desktopPhoneInput = document.getElementById('phone') as HTMLInputElement | null;
          const desktopAddressInput = document.getElementById('address') as HTMLInputElement | null;
          const desktopCityInput = document.getElementById('city') as HTMLInputElement | null;
          const desktopDistrictInput = document.getElementById('district') as HTMLInputElement | null;
          const desktopInstructionsInput = document.getElementById('instructions') as HTMLTextAreaElement | null;
          const draft = {
            name: mobileAddressLabelInput?.value || addressNameInput?.value || '',
            fullName: mobileFullNameInput?.value || desktopFullNameInput?.value || '',
            phone: mobilePhoneInput?.value || desktopPhoneInput?.value || '',
            address: mobileAddressInput?.value || desktopAddressInput?.value || '',
            city: mobileCityInput?.value || desktopCityInput?.value || '',
            district: mobileDistrictInput?.value || desktopDistrictInput?.value || '',
            instructions: mobileInstructionsInput?.value || desktopInstructionsInput?.value || '',
            latitude: addressLatInput?.value || '',
            longitude: addressLngInput?.value || '',
            updatedAt: Date.now()
          };
          localStorage.setItem(GUEST_SHIPPING_STORAGE_KEY, JSON.stringify(draft));
        } catch (_) {}
      }

      function loadGuestShippingDraft() {
        if (currentUserId) return null;
        try {
          const raw = localStorage.getItem(GUEST_SHIPPING_STORAGE_KEY);
          if (!raw) return null;
          return JSON.parse(raw);
        } catch (_) {
          return null;
        }
      }

      function applyGuestShippingDraftToMobile() {
        const draft = loadGuestShippingDraft();
        if (!draft) return;
        if (mobileAddressLabelInput && !mobileAddressLabelInput.value) mobileAddressLabelInput.value = draft.name || '';
        if (mobileFullNameInput && !mobileFullNameInput.value) mobileFullNameInput.value = draft.fullName || '';
        if (mobilePhoneInput && !mobilePhoneInput.value) mobilePhoneInput.value = draft.phone || '';
        if (mobileAddressInput && !mobileAddressInput.value) mobileAddressInput.value = draft.address || '';
        if (mobileCityInput && !mobileCityInput.value) mobileCityInput.value = draft.city || '';
        if (mobileDistrictInput && !mobileDistrictInput.value) mobileDistrictInput.value = draft.district || '';
        if (mobileInstructionsInput && !mobileInstructionsInput.value) mobileInstructionsInput.value = draft.instructions || '';
        if (addressLatInput && !addressLatInput.value && draft.latitude) addressLatInput.value = String(draft.latitude);
        if (addressLngInput && !addressLngInput.value && draft.longitude) addressLngInput.value = String(draft.longitude);
        if (mobileDeliveryAddress && draft.address) {
          mobileDeliveryAddress.textContent = [draft.address, draft.district, draft.city].filter(Boolean).join(', ');
        }
        if (mobileDeliveryTypeLabel) mobileDeliveryTypeLabel.textContent = resolveTypedAddressLabel();
        updateMobileInstructionsPreview(draft.instructions || '');
      }

      function loadGuestAddresses(): any[] {
        if (currentUserId) return [];
        try {
          const raw = localStorage.getItem(GUEST_ADDRESSES_STORAGE_KEY);
          const list = raw ? JSON.parse(raw) : [];
          return Array.isArray(list) ? list : [];
        } catch (_) {
          return [];
        }
      }

      function saveGuestAddresses(list: any[]) {
        if (currentUserId) return;
        try {
          localStorage.setItem(GUEST_ADDRESSES_STORAGE_KEY, JSON.stringify(list.slice(0, 8)));
        } catch (_) {}
      }

      function getSelectedGuestAddressId() {
        if (currentUserId) return '';
        return localStorage.getItem(GUEST_SELECTED_ADDRESS_KEY) || '';
      }

      function setSelectedGuestAddressId(id: string) {
        if (currentUserId) return;
        try {
          localStorage.setItem(GUEST_SELECTED_ADDRESS_KEY, id);
        } catch (_) {}
      }

