      function syncCoverageCircles() {
        const L = (window as any).L;
        const km = Math.max(0, deliverySettings.coverageRadiusKm ?? 5);
        const radiusM = km * 1000;
        const opts = {
          radius: radiusM,
          color: '#5d3fbb',
          weight: 2,
          opacity: 0.45,
          fillColor: '#5d3fbb',
          fillOpacity: 0.08,
        };
        if (checkoutMap && L) {
          if (checkoutCoverageCircle) {
            checkoutMap.removeLayer(checkoutCoverageCircle);
            checkoutCoverageCircle = null;
          }
          checkoutCoverageCircle = L.circle(STORE_EIPET_LAT_LNG, opts).addTo(checkoutMap);
          if (typeof checkoutCoverageCircle.bringToBack === 'function') checkoutCoverageCircle.bringToBack();
        }
        if (mobileMap && L) {
          if (mobileCoverageCircle) {
            mobileMap.removeLayer(mobileCoverageCircle);
            mobileCoverageCircle = null;
          }
          mobileCoverageCircle = L.circle(STORE_EIPET_LAT_LNG, opts).addTo(mobileMap);
          if (typeof mobileCoverageCircle.bringToBack === 'function') mobileCoverageCircle.bringToBack();
        }
      }

