---
import Layout from '../layouts/Layout.astro';
import OrderConfirmationModal from '../components/OrderConfirmationModal.astro';
---

<!-- Leaflet para el mapa de ubicación -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" is:inline></script>

<Layout title="Checkout - Eipet">
  <section class="py-8 lg:py-12 bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <!-- Breadcrumb (solo desktop) -->
      <nav class="hidden lg:flex mb-6 items-center gap-2 text-sm text-gray-600">
        <a href="/" class="hover:text-[#5d3fbb] transition-colors" data-astro-prefetch>Inicio</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <a href="/products" class="hover:text-[#5d3fbb] transition-colors" data-astro-prefetch>Productos</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-800 font-medium">Checkout</span>
      </nav>

      <!-- Título (solo desktop; en móvil el step 1 muestra "Tu carrito") -->
      <div class="hidden lg:block mb-8">
        <h1 class="text-3xl lg:text-4xl font-bold bg-linear-to-r from-[#5d3fbb] to-[#6d4fcc] bg-clip-text text-transparent mb-2">
          Finalizar Compra
        </h1>
        <p class="text-gray-600">Completa tu información para procesar tu pedido</p>
      </div>

      <!-- Loading State -->
      <div id="checkout-loading" class="text-center py-20">
        <div class="relative w-16 h-16 mx-auto mb-4">
          <div class="absolute inset-0 border-4 border-[#5d3fbb]/20 rounded-full"></div>
          <div class="absolute inset-0 border-4 border-transparent border-t-[#5d3fbb] rounded-full animate-spin"></div>
        </div>
        <p class="text-[#5d3fbb] font-semibold text-lg">Cargando carrito...</p>
      </div>

      <!-- Error State -->
      <div id="checkout-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-6 mb-6">
        <div class="flex items-center gap-3">
          <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <div>
            <h3 class="font-bold text-red-800 mb-1">Error</h3>
            <p id="error-message" class="text-red-600 text-sm"></p>
          </div>
        </div>
      </div>

      <!-- Empty Cart State -->
      <div id="empty-cart" class="hidden text-center py-20">
        <div class="max-w-md mx-auto">
          <div class="relative mb-6">
            <div class="absolute inset-0 bg-linear-to-br from-purple-100 to-pink-100 rounded-full blur-2xl opacity-50"></div>
            <svg class="relative w-24 h-24 mx-auto text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold text-gray-800 mb-2">Tu carrito está vacío</h3>
          <p class="text-gray-500 mb-6">Agrega productos a tu carrito antes de continuar.</p>
          <a
            href="/products"
            class="inline-flex items-center gap-2 bg-linear-to-r from-[#5d3fbb] to-[#6d4fcc] hover:from-[#6d4fcc] hover:to-[#7d5fdd] text-white font-semibold px-6 py-3 rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:scale-105 active:scale-95"
            data-astro-prefetch
          >
            <span>Ir a Productos</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Checkout Content -->
      <div id="checkout-content" class="hidden">
        <!-- Vista desktop: formulario + resumen -->
        <div id="checkout-desktop" class="hidden lg:grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
          <!-- Formulario de Checkout -->
          <div class="lg:col-span-2 space-y-6">
            <!-- Información de Envío -->
            <div class="bg-white rounded-xl shadow-md p-6">
              <h2 id="desktop-shipping-card-title" class="text-xl font-bold text-gray-900 mb-3 flex items-center gap-2">
                <svg class="w-6 h-6 text-[#5d3fbb]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span id="desktop-shipping-title-text">Información de Envío</span>
              </h2>

              <div class="flex rounded-xl overflow-hidden bg-[#5d3fbb] mb-4" role="tablist">
                <button
                  type="button"
                  id="desktop-tab-envio"
                  class="desktop-delivery-tab desktop-delivery-tab--active flex-1 flex items-center justify-center gap-2 py-3.5 px-4 bg-[#8b7bc4] text-black font-medium text-sm rounded-l-xl transition-colors"
                  data-delivery="envio"
                  aria-selected="true"
                >
                  <img src="/images/delivery-man.png" alt="" class="w-5 h-5 object-contain" />
                  Envio
                </button>
                <button
                  type="button"
                  id="desktop-tab-recoger"
                  class="desktop-delivery-tab flex-1 flex items-center justify-center py-3.5 px-4 text-[#f2c51f] font-medium text-sm rounded-r-xl transition-colors"
                  data-delivery="recoger"
                  aria-selected="false"
                >
                  Recoger en eipet
                </button>
              </div>

              <div id="desktop-shipping-envio-flow">
              <!-- Direcciones guardadas (solo si hay usuario logueado) -->
              <div id="saved-addresses-section" class="hidden mb-4">
                <div class="mb-3">
                  <label class="block text-sm font-semibold text-gray-700 mb-2">
                    Seleccionar dirección guardada
                  </label>
                  <div id="addresses-list" class="space-y-2 mb-3">
                    <!-- Se llenará dinámicamente -->
                  </div>
                  <button
                    type="button"
                    id="use-new-address-btn"
                    class="text-sm text-[#5d3fbb] hover:underline font-medium"
                  >
                    Usar nueva dirección
                  </button>
                </div>
              </div>

              <form id="shipping-form" class="space-y-4">
                <!-- Mapa: seleccionar ubicación de entrega (dentro del form para que lat/lng se envíen) -->
                <div id="map-address-section" class="mb-4">
                  <p class="text-sm text-gray-600 mb-2">
                    Usa tu ubicación actual o mueve el marcador al punto de entrega. Se pedirá permiso para acceder a tu ubicación.
                  </p>
                  <div id="map-status" class="text-sm text-gray-500 mb-2"></div>
                  <div class="relative w-full h-72 rounded-xl overflow-hidden border border-gray-200 bg-gray-100 shadow-sm isolate">
                    <div id="checkout-map" class="absolute inset-0 z-0 h-full w-full"></div>
                    <button
                      type="button"
                      id="use-my-location-btn"
                      class="absolute bottom-3 left-3 z-1000 pointer-events-auto inline-flex items-center gap-2 px-3 py-2 bg-[#5d3fbb] hover:bg-[#6d4fcc] text-white font-semibold rounded-lg transition-colors text-xs shadow-lg"
                    >
                      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      </svg>
                      <span class="text-left leading-tight">Usar mi ubicación actual</span>
                    </button>
                  </div>
                  <p class="text-xs text-gray-500 mt-2">Arrastra el marcador para ajustar el punto de entrega.</p>
                  <p id="map-coverage-note-desktop" class="text-xs text-[#5d3fbb]/90 mt-2 font-medium"></p>
                  <div
                    id="checkout-envio-gratis-msg-desktop"
                    class="hidden mt-3 rounded-xl border border-green-200 bg-green-50 px-3 py-2.5 text-sm font-semibold text-green-900"
                    role="status"
                  ></div>
                  <input type="hidden" id="address-lat" name="latitude" value="" />
                  <input type="hidden" id="address-lng" name="longitude" value="" />
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="fullName" class="block text-sm font-semibold text-gray-700 mb-2">
                      Nombre Completo <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="fullName"
                      name="fullName"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#5d3fbb]/20 focus:border-[#5d3fbb] transition-all"
                      placeholder="Juan Pérez"
                    />
                  </div>
                  <div>
                    <label for="phone" class="block text-sm font-semibold text-gray-700 mb-2">
                      Teléfono <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#5d3fbb]/20 focus:border-[#5d3fbb] transition-all"
                      placeholder="+591 70000000"
                    />
                  </div>
                </div>

                <div>
                  <label for="addressName" class="block text-sm font-semibold text-gray-700 mb-2">
                    Nombre de ubicación
                  </label>
                  <input
                    type="text"
                    id="addressName"
                    name="addressName"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#5d3fbb]/20 focus:border-[#5d3fbb] transition-all"
                    placeholder="Ej: Casa, Oficina, Casa abuela"
                  />
                </div>

                <div>
                  <label for="address" class="block text-sm font-semibold text-gray-700 mb-2">
                    Dirección <span class="text-red-500">*</span>
                  </label>
                  <input
                    type="text"
                    id="address"
                    name="address"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#5d3fbb]/20 focus:border-[#5d3fbb] transition-all"
                    placeholder="Calle, número, zona"
                  />
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="city" class="block text-sm font-semibold text-gray-700 mb-2">
                      Ciudad <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="city"
                      name="city"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#5d3fbb]/20 focus:border-[#5d3fbb] transition-all"
                      placeholder="La Paz"
                    />
                  </div>
                  <div>
                    <label for="district" class="block text-sm font-semibold text-gray-700 mb-2">
                      Zona/Distrito <span class="text-red-500">*</span>
                    </label>
                    <input
                      type="text"
                      id="district"
                      name="district"
                      required
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#5d3fbb]/20 focus:border-[#5d3fbb] transition-all"
                      placeholder="Zona Sur"
                    />
                  </div>
                </div>

                <div>
                  <label for="instructions" class="block text-sm font-semibold text-gray-700 mb-2">
                    Instrucciones de Entrega (Opcional)
                  </label>
                  <textarea
                    id="instructions"
                    name="instructions"
                    rows="3"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#5d3fbb]/20 focus:border-[#5d3fbb] transition-all resize-none"
                    placeholder="Ej: Llamar antes de llegar, dejar en recepción, etc."
                  ></textarea>
                </div>

                <div>
                  <label for="desktop-delivery-datetime" class="block text-sm font-semibold text-gray-700 mb-2">
                    Fecha y hora de envío (Opcional)
                  </label>
                  <input
                    type="datetime-local"
                    id="desktop-delivery-datetime"
                    class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 focus:border-[#5d3fbb] focus:outline-none focus:ring-1 focus:ring-[#5d3fbb]/30"
                  />
                  <p class="text-xs text-gray-500 mt-1">Si no eliges una, usaremos la fecha y hora actuales.</p>
                </div>
              </form>
              </div>

              <!-- Recoger en tienda (desktop) — misma estructura que móvil step 2 -->
              <div id="desktop-shipping-recoger-flow" class="hidden space-y-5">
                <div class="text-center">
                  <p class="text-xs font-semibold text-[#5d3fbb] uppercase tracking-wide">Recoger en la tienda</p>
                  <p class="text-lg font-bold text-gray-900">eipet</p>
                </div>

                <div>
                  <h2 class="text-base font-semibold text-gray-900 mb-2 flex items-center gap-2">
                    <svg class="w-5 h-5 text-[#5d3fbb]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    Ubicación
                  </h2>
                  <button
                    type="button"
                    id="desktop-pickup-map-toggle"
                    class="w-full flex items-center gap-3 rounded-xl border-2 border-[#5d3fbb]/40 bg-white px-4 py-3.5 text-left shadow-sm hover:border-[#5d3fbb] transition-colors"
                    aria-expanded="false"
                    aria-controls="desktop-pickup-map-wrap"
                  >
                    <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-purple-50 text-xl" aria-hidden="true">🐕</span>
                    <span class="flex-1 text-sm font-semibold text-gray-900">¿Cómo llegar a eipet?</span>
                    <svg class="w-5 h-5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </button>
                  <div id="desktop-pickup-map-wrap" class="hidden mt-3 rounded-xl border border-gray-200 overflow-hidden bg-gray-50">
                    <div class="relative h-56 w-full">
                      <div id="checkout-pickup-map-desktop" class="absolute inset-0 z-0 h-full w-full"></div>
                    </div>
                    <p class="text-[11px] text-gray-500 px-3 py-2">Ubicación de la tienda Eipet. Cierra el mapa cuando termines.</p>
                  </div>
                </div>

                <div>
                  <h2 class="text-base font-semibold text-gray-900 mb-2">Hora de recoger</h2>
                  <button
                    type="button"
                    id="desktop-pickup-schedule-toggle"
                    class="w-full flex items-center gap-3 rounded-xl border-2 border-[#5d3fbb]/40 bg-white px-4 py-3.5 text-left shadow-sm hover:border-[#5d3fbb] transition-colors"
                    aria-expanded="false"
                    aria-controls="desktop-pickup-schedule-wrap"
                  >
                    <svg class="w-6 h-6 shrink-0 text-[#5d3fbb]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span class="flex-1 text-sm font-semibold text-gray-900">Elija qué hora recoger o día</span>
                    <svg class="w-5 h-5 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </button>
                  <div id="desktop-pickup-schedule-wrap" class="hidden mt-3 rounded-xl border border-gray-200 bg-white p-4">
                    <label for="desktop-pickup-datetime" class="block text-xs font-semibold text-gray-700 mb-2">Fecha y hora aproximada</label>
                    <input
                      type="datetime-local"
                      id="desktop-pickup-datetime"
                      class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm text-gray-900 focus:border-[#5d3fbb] focus:outline-none focus:ring-1 focus:ring-[#5d3fbb]/30"
                    />
                  </div>
                </div>

                <div class="flex items-start gap-3 rounded-xl border border-gray-100 bg-gray-50/80 p-4">
                  <svg class="w-5 h-5 mt-0.5 shrink-0 text-[#5d3fbb]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-900">Instrucciones para recoger</p>
                    <textarea
                      id="desktop-pickup-instructions-input"
                      rows="3"
                      class="mt-2 w-full rounded-lg border border-gray-300 px-3 py-2 text-xs text-gray-700 focus:border-[#5d3fbb] focus:outline-none focus:ring-1 focus:ring-[#5d3fbb]/30 resize-none"
                      placeholder="Ej: Recojo yo personalmente, tocar timbre al llegar, esperar 10 min, etc."
                    ></textarea>
                  </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="desktop-recoger-fullName" class="block text-xs font-semibold text-gray-700 mb-1 sm:text-sm sm:mb-2">Nombre completo <span class="text-red-500">*</span></label>
                    <input
                      type="text"
                      id="desktop-recoger-fullName"
                      class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-[#5d3fbb] focus:outline-none focus:ring-1 focus:ring-[#5d3fbb]/30 sm:px-4 sm:py-3 sm:text-sm"
                      placeholder="Quien recoge el pedido"
                      autocomplete="name"
                    />
                  </div>
                  <div>
                    <label for="desktop-recoger-phone" class="block text-xs font-semibold text-gray-700 mb-1 sm:text-sm sm:mb-2">Teléfono <span class="text-red-500">*</span></label>
                    <input
                      type="tel"
                      id="desktop-recoger-phone"
                      class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm focus:border-[#5d3fbb] focus:outline-none focus:ring-1 focus:ring-[#5d3fbb]/30 sm:px-4 sm:py-3 sm:text-sm"
                      placeholder="+591 70000000"
                      autocomplete="tel"
                    />
                  </div>
                </div>
              </div>

            </div>

            <!-- Método de Pago -->
            <div class="bg-white rounded-xl shadow-md p-6">
              <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                <svg class="w-6 h-6 text-[#5d3fbb]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
                Método de Pago
              </h2>
              
              <!-- Métodos de pago guardados (solo si hay usuario logueado) -->
              <div id="saved-payment-methods-section" class="hidden mb-4">
                <div class="mb-3">
                  <label class="block text-sm font-semibold text-gray-700 mb-2">
                    Seleccionar método de pago guardado
                  </label>
                  <div id="payment-methods-list" class="space-y-2 mb-3">
                    <!-- Se llenará dinámicamente -->
                  </div>
                  <button
                    type="button"
                    id="use-new-payment-btn"
                    class="text-sm text-[#5d3fbb] hover:underline font-medium"
                  >
                    Usar otro método de pago
                  </button>
                </div>
              </div>
              
              <div id="payment-methods-options" class="space-y-3">
                <button
                  type="button"
                  id="desktop-payment-method-btn"
                  class="w-full flex items-center justify-between bg-[#5d3fbb] rounded-xl px-4 py-3 text-white active:scale-[0.99] transition-transform"
                >
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-lg bg-black/20 flex items-center justify-center">
                      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                      </svg>
                    </div>
                    <div class="text-left">
                      <p class="text-sm font-semibold text-amber-300 leading-tight">Métodos de pago</p>
                      <p id="desktop-selected-payment-label" class="text-xs text-white leading-tight">Codigo QR</p>
                    </div>
                  </div>
                  <div class="w-9 h-9 rounded-lg bg-white flex items-center justify-center">
                    <span id="desktop-selected-payment-short" class="text-xs font-semibold text-[#5d3fbb]">QR</span>
                  </div>
                </button>
                <div class="hidden">
                  <input type="radio" name="paymentMethod" value="cash" />
                  <input type="radio" name="paymentMethod" value="qr" checked />
                  <input type="radio" name="paymentMethod" value="card" />
                </div>
              </div>
            </div>

            <!-- Datos de Facturación -->
            <div class="bg-white rounded-xl shadow-md p-6">
              <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                <svg class="w-6 h-6 text-[#5d3fbb]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
