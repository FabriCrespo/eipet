      // Guardar carrito en localStorage (formato compatible con el resto de la app)
      function saveCartToStorage() {
        const items = cartItems.map((item) => {
          const product = productsData.get(item.productId);
          return {
            productId: item.productId,
            quantity: item.quantity || 1,
            product: product ? {
              id: product.id,
              name: product.name,
              price: product.price,
              image: product.image,
              brandName: product.brandName
            } : undefined
          };
        });
        localStorage.setItem('cart', JSON.stringify({ items, lastUpdated: Date.now() }));
        if ((window as any).updateCartCount) (window as any).updateCartCount();
        window.dispatchEvent(new CustomEvent('cart-updated'));
      }

