        saveGuestShippingDraft();
        updateTotals();
      }

      function initCheckoutMap() {
        if (!checkoutMapDiv || checkoutMap) return;
        const L = (window as any).L;
        if (!L) {
          setMapStatus('Cargando mapa...');
          setTimeout(initCheckoutMap, 300);
          return;
        }
        checkoutMap = L.map('checkout-map').setView(DEFAULT_CENTER, DEFAULT_ZOOM);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© OpenStreetMap'
        }).addTo(checkoutMap);
        syncCoverageCircles();
        addEipetStoreMarker(checkoutMap, L);
        checkoutMap.on('click', (e: any) => {
          const { lat, lng } = e.latlng;
          if (checkoutMarker) checkoutMarker.setLatLng([lat, lng]);
          else {
            checkoutMarker = L.marker([lat, lng], { draggable: true, zIndexOffset: 600 }).addTo(checkoutMap);
            checkoutMarker.on('dragend', () => {
              const pos = checkoutMarker.getLatLng();
              updateMarkerPosition(pos.lat, pos.lng);
              fitMapToStoreAndDelivery(checkoutMap, L, pos.lat, pos.lng);
            });
          }
          updateMarkerPosition(lat, lng);
          fitMapToStoreAndDelivery(checkoutMap, L, lat, lng);
        });
        setTimeout(() => checkoutMap.invalidateSize(), 200);
        setMapStatus(
          'El icono de tienda es Eipet; el pin azul es tu entrega. Clic o GPS para colocar la entrega.'
        );
      }

