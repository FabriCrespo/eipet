  <script>
    (async () => {
      // Declarar antes de cualquier await: si Firebase dispara callbacks pronto, evita TDZ (ReferenceError: userAddresses is not defined).
      let userAddresses: any[] = [];

      // Verificar autenticación (solo requerida al confirmar, no para ver el checkout)
      const { getCurrentUser, onAuthStateChange } = await import('../lib/auth');
      
      let currentUser: any = null;
      let currentUserId: string | null = null;
      let cartItems: any[] = [];
      /** Productos para el carrusel “También te puede interesar” (móvil step 1) */
      let checkoutSuggestionPool: any[] = [];
      let productsData: Map<string, any> = new Map();
      let shippingCost = 0;
      const PAID_SHIPPING_FALLBACK_BS = 15;
      const DEFAULT_DELIVERY_CLIENT = {
        minPurchaseAmount: 200,
        coverageRadiusKm: 5,
        freeDeliveryEnabled: true,
        messageTeFaltan: 'Te faltan {amount} Bs para envío gratis',
        messageFueraCobertura: 'Tu dirección está fuera de nuestra zona de cobertura.',
        messageEnvioGratis: '¡Felicidades! Tienes envío gratis',
      };
      let deliverySettings: typeof DEFAULT_DELIVERY_CLIENT = { ...DEFAULT_DELIVERY_CLIENT };
      let checkoutCoverageCircle: any = null;
      let mobileCoverageCircle: any = null;
      let lastOutOfCoverage = false;
      let lastFreeDeliveryPromo = false;
      let userSawTeFaltanMessage = false;
      let userPaymentMethods: any[] = [];
      let selectedAddressId: string | null = null;
      let selectedPaymentMethodId: string | null = null;
      let useManualAddress = true;
      let useManualPayment = true;

      // Función para obtener y actualizar el usuario actual
      async function updateCurrentUser() {
        console.log('🔐 [CHECKOUT] updateCurrentUser - Verificando autenticación...');
        const firebaseUser = getCurrentUser();
        console.log('🔐 [CHECKOUT] firebaseUser desde getCurrentUser():', firebaseUser);
        console.log('🔐 [CHECKOUT] auth.currentUser:', (await import('../lib/firebase')).auth.currentUser);
        
        if (firebaseUser) {
          currentUserId = firebaseUser.uid;
          console.log('🔐 [CHECKOUT] Usuario encontrado, currentUserId:', currentUserId);
        } else {
          currentUserId = null;
          console.log('🔐 [CHECKOUT] No se encontró usuario autenticado');
        }
        return currentUserId;
      }

      // Esperar a que Firebase Auth esté inicializado usando onAuthStateChange
      let authInitialized = false;
      const unsubscribeAuth = onAuthStateChange((firebaseUser) => {
        console.log('🔐 [CHECKOUT] onAuthStateChange - Usuario cambió:', firebaseUser);
        if (!authInitialized) {
          authInitialized = true;
          console.log('🔐 [CHECKOUT] Firebase Auth inicializado');
        }
        
        if (firebaseUser) {
          currentUserId = firebaseUser.uid;
          console.log('🔐 [CHECKOUT] Usuario autenticado, currentUserId:', currentUserId);
          // Recargar direcciones y métodos de pago si el usuario se autentica y el checkout está visible
          if (checkoutContent && !checkoutContent.classList.contains('hidden')) {
            console.log('🔐 [CHECKOUT] Checkout visible, cargando direcciones y métodos de pago...');
            loadUserAddresses();
            loadUserPaymentMethods();
          }
        } else {
          currentUserId = null;
          console.log('🔐 [CHECKOUT] Usuario desautenticado');
        }
      });
      
      // Esperar un momento para que Firebase Auth se inicialice
      await new Promise(resolve => setTimeout(resolve, 100));
      
      // Verificar usuario después de esperar
      await updateCurrentUser();

      // Elementos del DOM
      const loadingDiv = document.getElementById('checkout-loading');
      const errorDiv = document.getElementById('checkout-error');
      const errorMessage = document.getElementById('error-message');
      const emptyCartDiv = document.getElementById('empty-cart');
      const checkoutContent = document.getElementById('checkout-content');
      const orderItemsDiv = document.getElementById('order-items');
      const subtotalSpan = document.getElementById('subtotal');
      const desktopSummarySubtotal = document.getElementById('desktop-summary-subtotal');
      const shippingCostSpan = document.getElementById('shipping-cost');
      const discountSpan = document.getElementById('discount');
      const discountRow = document.getElementById('discount-row');
      const totalSpan = document.getElementById('total');
      const confirmBtn = document.getElementById('confirm-order-btn');
      const confirmBtnText = document.getElementById('confirm-btn-text');
      const confirmBtnLoading = document.getElementById('confirm-btn-loading');
      const shippingForm = document.getElementById('shipping-form') as HTMLFormElement;
      const savedAddressesSection = document.getElementById('saved-addresses-section');
      const addressesList = document.getElementById('addresses-list');
