      function encodeSavedPickValue(source: 'user' | 'guest', id: string) {
        return `${source}|${encodeURIComponent(id)}`;
      }

      function parseSavedPickValue(v: string): { source: 'user' | 'guest'; id: string } | null {
        if (!v) return null;
        const pipe = v.indexOf('|');
        if (pipe < 1) return null;
        const source = v.slice(0, pipe) as 'user' | 'guest';
        if (source !== 'user' && source !== 'guest') return null;
        try {
          const id = decodeURIComponent(v.slice(pipe + 1));
          return { source, id };
        } catch (_) {
          return null;
        }
      }

