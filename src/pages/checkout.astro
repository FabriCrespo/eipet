          mobileMarker.on('dragend', () => {
            const p = mobileMarker.getLatLng();
            updateMobileMarkerPosition(p.lat, p.lng);
            fitMapToStoreAndDelivery(mobileMap, L, p.lat, p.lng);
          });
        }
        updateMobileMarkerPosition(lat, lng);
        fitMapToStoreAndDelivery(mobileMap, L, lat, lng);
      }

      /** Al entrar al paso 2: mismo ritmo que web (init mapa → 600 ms → pin con GPS o coords guardadas) */
      function applyMobileStep2MapAndLocation() {
        setTimeout(() => {
          initMobileMap();
          setTimeout(() => {
            const latStr = addressLatInput?.value?.trim();
            const lngStr = addressLngInput?.value?.trim();
            const lat = latStr ? parseFloat(latStr) : NaN;
            const lng = lngStr ? parseFloat(lngStr) : NaN;
            const hasValidSavedCoords = !isNaN(lat) && !isNaN(lng) && lat !== 0 && lng !== 0;
            if (hasValidSavedCoords) {
              placeMobileMarkerAt(lat, lng);
            } else {
              useMyLocationMobile();
            }
          }, 600);
        }, 100);
      }

      /** Cuando no hay direcciones guardadas, inicializar mapa y pedir ubicación actual */
      function applyDefaultAddressSource() {
        if (userAddresses.length > 0) return;
        if (!checkoutContent || checkoutContent.classList.contains('hidden')) return;
        setTimeout(() => {
          initCheckoutMap();
          setTimeout(() => useMyLocation(), 600);
        }, 100);
      }

      function useMyLocation() {
        if (!navigator.geolocation) {
          setMapStatus('Tu navegador no soporta geolocalización.', true);
          return;
        }
        setMapStatus('Solicitando permiso de ubicación...');
        navigator.geolocation.getCurrentPosition(
          (pos) => {
            const lat = pos.coords.latitude;
            const lng = pos.coords.longitude;
            const L = (window as any).L;
            if (!checkoutMap || !L) return;
            if (checkoutMarker) checkoutMarker.setLatLng([lat, lng]);
            else {
              checkoutMarker = L.marker([lat, lng], { draggable: true, zIndexOffset: 600 }).addTo(checkoutMap);
              checkoutMarker.on('dragend', () => {
                const p = checkoutMarker.getLatLng();
                updateMarkerPosition(p.lat, p.lng);
                fitMapToStoreAndDelivery(checkoutMap, L, p.lat, p.lng);
              });
            }
            updateMarkerPosition(lat, lng);
            fitMapToStoreAndDelivery(checkoutMap, L, lat, lng);
          },
          (err) => {
            const msg = err.code === 1 ? 'Permiso de ubicación denegado. Puedes marcar el punto en el mapa.' : 'No se pudo obtener la ubicación. Marca el punto en el mapa.';
            setMapStatus(msg, true);
          },
          { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
        );
      }

      function useMyLocationMobile() {
        if (!navigator.geolocation) {
          const statusEl = document.getElementById('mobile-map-status');
          if (statusEl) statusEl.textContent = 'Tu navegador no soporta geolocalización.';
          return;
        }
        const statusEl = document.getElementById('mobile-map-status');
        if (statusEl) statusEl.textContent = 'Solicitando permiso de ubicación...';
        navigator.geolocation.getCurrentPosition(
          (pos) => {
            const lat = pos.coords.latitude;
            const lng = pos.coords.longitude;
            const L = (window as any).L;
            if (!mobileMap || !L) return;
            if (mobileMarker) mobileMarker.setLatLng([lat, lng]);
            else {
              mobileMarker = L.marker([lat, lng], { draggable: true, zIndexOffset: 600 }).addTo(mobileMap);
              mobileMarker.on('dragend', () => {
                const p = mobileMarker.getLatLng();
                updateMobileMarkerPosition(p.lat, p.lng);
                fitMapToStoreAndDelivery(mobileMap, L, p.lat, p.lng);
              });
            }
            updateMobileMarkerPosition(lat, lng);
            fitMapToStoreAndDelivery(mobileMap, L, lat, lng);
          },
          (err) => {
            const msg = err.code === 1 ? 'Permiso de ubicación denegado. Marca el punto en el mapa.' : 'No se pudo obtener la ubicación. Marca el punto en el mapa.';
            if (statusEl) statusEl.textContent = msg;
          },
          { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
        );
      }

      // Función para mostrar error
      function showError(message: string) {
        if (errorDiv && errorMessage) {
          errorMessage.textContent = message;
          errorDiv.classList.remove('hidden');
        }
      }

      // Función para ocultar error
      function hideError() {
        if (errorDiv) {
          errorDiv.classList.add('hidden');
        }
      }

      // Función para formatear precio
      function formatPrice(price: number): string {
        return price.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      }

      // Cargar carrito y productos
      async function loadCheckout() {
        try {
          hideError();
          
          // Obtener carrito desde localStorage
          let cartData: any = null;
          try {
            const cartStorage = localStorage.getItem('cart');
            if (cartStorage) {
              cartData = JSON.parse(cartStorage);
            }
          } catch (e) {
            // Error silencioso
          }
          
          if (!cartData || !cartData.items || cartData.items.length === 0) {
            if (loadingDiv) loadingDiv.classList.add('hidden');
            if (emptyCartDiv) emptyCartDiv.classList.remove('hidden');
            return;
          }

          // Convertir items del localStorage al formato esperado
          cartItems = cartData.items.map((item: any) => {
            const productId = item.productId || item.id || item.product?.id;
            const quantity = item.quantity || 1;
            return {
              productId: productId,
              quantity: quantity
            };
          }).filter((item: any) => item.productId);

          // Obtener información de productos
          const { getProductById } = await import('../lib/db/products');
          const { getBrands } = await import('../lib/db/brands');
          
          const brandsResult = await getBrands();
          const brandsMap = new Map();
          if (brandsResult.data) {
            brandsResult.data.forEach((b: any) => brandsMap.set(b.id, b));
          }

          // Obtener detalles de cada producto
          for (const item of cartData.items) {
            const productId = item.productId || item.id;
            
            if (item.product) {
              productsData.set(productId, {
                ...item.product,
                brandName: item.product.brandName || 'Sin marca',
                quantity: item.quantity
              });
            } else {
              const productResult = await getProductById(productId);
              if (productResult.data) {
                const product = productResult.data;
                const brandName = product.brand && brandsMap.has(product.brand) 
                  ? brandsMap.get(product.brand).name 
                  : 'Sin marca';
                
                productsData.set(productId, {
                  ...product,
                  brandName,
                  quantity: item.quantity
                });
              }
            }
          }

          try {
            const { getDeliverySettings } = await import('../lib/db/storeSettings');
            const res = await getDeliverySettings();
            mergeDeliveryFromRemote(res.data || {});
          } catch (_) {
            mergeDeliveryFromRemote({});
          }

          // Renderizar items (desktop y móvil)
          renderOrderItems();
          renderMobileStep1Items();
          updateTotals();

          // Ocultar loading y mostrar contenido
          if (loadingDiv) loadingDiv.classList.add('hidden');
          if (checkoutContent) checkoutContent.classList.remove('hidden');
          if (confirmBtn) (confirmBtn as HTMLButtonElement).disabled = false;

          // Inicializar mapa solo en desktop (en móvil step 1 no muestra mapa)
          if (checkoutDesktop && typeof window !== 'undefined' && window.innerWidth >= 1024) {
            setTimeout(() => initCheckoutMap(), 300);
          }

          // Esperar un poco más para asegurar que Firebase Auth esté listo
          await new Promise(resolve => setTimeout(resolve, 200));
          
          // Verificar nuevamente el usuario antes de cargar datos
          await updateCurrentUser();
          
          // Cargar datos del usuario si está logueado
          if (currentUserId) {
            console.log('👤 [CHECKOUT] Usuario logueado, cargando datos del usuario...');
            console.log('👤 [CHECKOUT] currentUserId:', currentUserId);
            await loadUserData();
            console.log('👤 [CHECKOUT] loadUserData completado');
            await loadUserAddresses();
            console.log('👤 [CHECKOUT] loadUserAddresses completado');
            await loadUserPaymentMethods();
            console.log('👤 [CHECKOUT] loadUserPaymentMethods completado');
          } else {
            console.log('👤 [CHECKOUT] No hay usuario logueado después de verificar');
            console.log('👤 [CHECKOUT] Esperando a que Firebase Auth se inicialice...');
            // Esperar un poco más y verificar de nuevo
            setTimeout(async () => {
              await updateCurrentUser();
              if (currentUserId) {
                console.log('👤 [CHECKOUT] Usuario encontrado después de esperar, cargando datos...');
                await loadUserData();
                await loadUserAddresses();
                await loadUserPaymentMethods();
              } else {
                console.log('👤 [CHECKOUT] Aún no hay usuario después de esperar');
              }
              applyDefaultAddressSource();
            }, 500);
          }
          // Sin dirección guardada: por defecto "Seleccionar en el mapa" con ubicación actual
          applyDefaultAddressSource();
          void loadCheckoutSuggestions();
        } catch (error: any) {
          showError(error.message || 'Error al cargar el carrito');
          if (loadingDiv) loadingDiv.classList.add('hidden');
        }
      }

      /**
       * Sincroniza el checkout con `localStorage.cart` cuando el usuario cambia el carrito
       * desde el panel del header (u otra pestaña). El script del header emite `cart-updated`.
       */
      async function refreshCheckoutFromCartStorage() {
        let cartData: any = null;
        try {
          const raw = localStorage.getItem('cart');
          if (raw) cartData = JSON.parse(raw);
        } catch (_) {
          return;
        }

        if (!cartData || !cartData.items || cartData.items.length === 0) {
          cartItems = [];
          productsData.clear();
          if (checkoutContent) checkoutContent.classList.add('hidden');
          if (emptyCartDiv) emptyCartDiv.classList.remove('hidden');
          if (confirmBtn) (confirmBtn as HTMLButtonElement).disabled = true;
          const suggWrap = document.getElementById('checkout-suggestions-wrap');
          if (suggWrap) suggWrap.classList.add('hidden');
          renderOrderItems();
          renderMobileStep1Items();
          updateTotals();
          applyCheckoutDeliveryModeUI();
          return;
        }

        cartItems = cartData.items
          .map((item: any) => {
            const productId = item.productId || item.id || item.product?.id;
            const quantity = item.quantity || 1;
            return { productId, quantity };
          })
          .filter((item: { productId: string }) => item.productId);

        const keepIds = new Set(cartItems.map((i) => i.productId));
        for (const id of [...productsData.keys()]) {
          if (!keepIds.has(id)) productsData.delete(id);
        }

        const { getProductById } = await import('../lib/db/products');
        const { getBrands } = await import('../lib/db/brands');

        const brandsResult = await getBrands();
        const brandsMap = new Map();
        if (brandsResult.data) {
          brandsResult.data.forEach((b: any) => brandsMap.set(b.id, b));
        }

        for (const item of cartData.items) {
          const productId = item.productId || item.id;
          if (!productId) continue;

          if (item.product) {
            productsData.set(productId, {
              ...item.product,
              brandName: item.product.brandName || 'Sin marca',
              quantity: item.quantity,
            });
          } else if (productsData.has(productId)) {
            const p = productsData.get(productId);
            if (p) p.quantity = item.quantity;
          } else {
            const productResult = await getProductById(productId);
            if (productResult.data) {
              const product = productResult.data;
              const brandName =
                product.brand && brandsMap.has(product.brand)
                  ? brandsMap.get(product.brand).name
                  : 'Sin marca';
              productsData.set(productId, {
                ...product,
                brandName,
                quantity: item.quantity,
              });
            }
          }
        }

        renderOrderItems();
        renderMobileStep1Items();
        updateTotals();
        applyCheckoutDeliveryModeUI();
        renderCheckoutSuggestions();

        if (checkoutContent) checkoutContent.classList.remove('hidden');
        if (emptyCartDiv) emptyCartDiv.classList.add('hidden');
        if (confirmBtn) (confirmBtn as HTMLButtonElement).disabled = false;
      }

