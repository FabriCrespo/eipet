      /**
       * Geocodificación inversa: Nominatim primero; si falla (CORS/503), respaldo solo con BigDataCloud (CORS OK).
       * No usar Photon/komoot desde el navegador.
       */
      async function reverseGeocode(lat: number, lng: number, forMobile = false) {
        const statusEl = forMobile ? document.getElementById('mobile-map-status') : mapStatus;
        if (statusEl) statusEl.textContent = 'Obteniendo dirección...';
        if (!forMobile && mapStatus) setMapStatus('Obteniendo dirección...');

        const coordStr = `${lat.toFixed(6)}, ${lng.toFixed(6)}`;

        async function tryNominatim(): Promise<{
          fullAddress: string;
          city: string;
          district: string;
        } | null> {
          try {
            const url = `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${encodeURIComponent(lat)}&lon=${encodeURIComponent(lng)}&zoom=18&addressdetails=1`;
            const res = await fetch(url, {
              headers: { 'Accept-Language': 'es', Accept: 'application/json' },
            });
            if (!res.ok) return null;
            const data = await res.json();
            if (data.error) return null;
            const a = data.address || {};
            const fullAddress =
              [a.road, a.house_number, a.suburb, a.neighbourhood].filter(Boolean).join(', ') ||
              data.display_name ||
              '';
            const city = a.city || a.town || a.village || a.municipality || a.state || '';
            const district = a.suburb || a.neighbourhood || a.quarter || a.district || '';
            if (!fullAddress && !city) return null;
            return { fullAddress, city, district };
          } catch {
            return null;
          }
        }

        async function tryBigDataCloud(): Promise<{
          fullAddress: string;
          city: string;
          district: string;
        } | null> {
          try {
            const url = `https://api.bigdatacloud.net/data/reverse-geocode-client?latitude=${encodeURIComponent(lat)}&longitude=${encodeURIComponent(lng)}&localityLanguage=es`;
            const res = await fetch(url, { headers: { Accept: 'application/json' } });
            if (!res.ok) return null;
            const data = await res.json();
            const city =
              data.city ||
              data.locality ||
              (typeof data.principalSubdivision === 'string' ? data.principalSubdivision : '') ||
              '';
            const locality = typeof data.locality === 'string' ? data.locality : '';
            const district =
              locality && city && locality !== city
                ? locality
                : (data.suburb as string) || (data.neighbourhood as string) || '';
            let fullAddress = '';
            if (locality && city) fullAddress = locality === city ? city : `${locality}, ${city}`;
            else fullAddress = city || locality || '';
            if (!fullAddress && !city) return null;
            return { fullAddress: fullAddress || city, city: city || locality, district };
          } catch {
            return null;
          }
        }

        let parts = await tryNominatim();
        if (!parts) parts = await tryBigDataCloud();

        if (parts) {
          const line = parts.fullAddress.trim() || parts.city.trim() || coordStr;
          if (forMobile) {
            const addrInput = document.getElementById('mobile-address') as HTMLInputElement;
            const cityInput = document.getElementById('mobile-city') as HTMLInputElement;
            const distInput = document.getElementById('mobile-district') as HTMLInputElement;
            if (addrInput) addrInput.value = line;
            if (cityInput) cityInput.value = parts.city;
            if (distInput) distInput.value = parts.district;
            if (mobileDeliveryAddress) mobileDeliveryAddress.textContent = line;
            if (statusEl) statusEl.textContent = 'Dirección actualizada. Puedes editar los campos si hace falta.';
          } else {
            const addressInput = document.getElementById('address') as HTMLInputElement;
            const cityInput = document.getElementById('city') as HTMLInputElement;
            const districtInput = document.getElementById('district') as HTMLInputElement;
            if (addressInput) addressInput.value = line;
            if (cityInput) cityInput.value = parts.city;
            if (districtInput) districtInput.value = parts.district;
            setMapStatus('Dirección actualizada. Puedes editar los campos si hace falta.');
          }
          return;
        }

        if (forMobile) {
          const addrInput = document.getElementById('mobile-address') as HTMLInputElement;
          if (addrInput) addrInput.value = coordStr;
          if (mobileDeliveryAddress) mobileDeliveryAddress.textContent = coordStr;
          if (statusEl) statusEl.textContent = 'No se pudo obtener la dirección. Completa los campos manualmente.';
        } else {
          setMapStatus('No se pudo obtener la dirección. Completa los campos manualmente.', true);
          const addressInput = document.getElementById('address') as HTMLInputElement;
          if (addressInput) addressInput.value = coordStr;
        }
      }

      function updateMarkerPosition(lat: number, lng: number) {
        if (addressLatInput) addressLatInput.value = String(lat);
        if (addressLngInput) addressLngInput.value = String(lng);
