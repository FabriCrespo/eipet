      function getMobileDeliveryScheduleValue(): string {
        const d = mobileDeliveryDateInput?.value?.trim() ?? '';
        const t = mobileDeliveryTimeInput?.value?.trim() ?? '';
        if (!d || !t) return '';
        return `${d}T${t}`;
      }

      function getResolvedDeliveryScheduleValue(): string {
        return getMobileDeliveryScheduleValue() || getDesktopDeliveryScheduleValue() || nowLocalDateTimeValue();
      }

      function syncDeliveryScheduleInputs(source: 'desktop' | 'mobile') {
        if (source === 'desktop') {
          const value = getDesktopDeliveryScheduleValue();
          if (!value || !mobileDeliveryDateInput || !mobileDeliveryTimeInput) return;
          const [d, t] = value.split('T');
          if (d) mobileDeliveryDateInput.value = d;
          if (t) mobileDeliveryTimeInput.value = t.slice(0, 5);
          return;
        }
        const value = getMobileDeliveryScheduleValue();
        if (!value || !desktopDeliveryDatetimeInput) return;
        desktopDeliveryDatetimeInput.value = value;
      }

