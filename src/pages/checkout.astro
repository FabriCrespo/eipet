      function haversineKm(lat1: number, lon1: number, lat2: number, lon2: number): number {
        const R = 6371;
        const toRad = (d: number) => (d * Math.PI) / 180;
        const dLat = toRad(lat2 - lat1);
        const dLon = toRad(lon2 - lon1);
        const a =
          Math.sin(dLat / 2) * Math.sin(dLat / 2) +
          Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLon / 2) * Math.sin(dLon / 2);
        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return R * c;
      }

      function mergeDeliveryFromRemote(raw: any) {
        const r = raw && typeof raw === 'object' ? raw : {};
        deliverySettings = {
          minPurchaseAmount: Number(r.minPurchaseAmount ?? DEFAULT_DELIVERY_CLIENT.minPurchaseAmount),
          coverageRadiusKm: Number(r.coverageRadiusKm ?? DEFAULT_DELIVERY_CLIENT.coverageRadiusKm),
          freeDeliveryEnabled: r.freeDeliveryEnabled !== false,
          messageTeFaltan: String(r.messageTeFaltan || DEFAULT_DELIVERY_CLIENT.messageTeFaltan),
          messageFueraCobertura: String(r.messageFueraCobertura || DEFAULT_DELIVERY_CLIENT.messageFueraCobertura),
          messageEnvioGratis: String(r.messageEnvioGratis || DEFAULT_DELIVERY_CLIENT.messageEnvioGratis),
        };
        updateMapCoverageNotes();
        syncCoverageCircles();
      }

