---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <section class="py-8 lg:py-12 bg-gray-50 min-h-screen">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-2">
          Descuentos y envío
        </h1>
        <p class="text-gray-600">
          Configura envío gratis y promociones por marca o por producto (los precios del catálogo se actualizan al guardar). Revisa las métricas de envío y conversión.
        </p>
      </div>

      <!-- Lista de envío gratis -->
      <div class="bg-white rounded-3xl border border-gray-200 shadow-md overflow-hidden mb-8">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
          <h2 class="text-xl font-bold text-gray-900">Configuración de envío gratis</h2>
          <p class="text-sm text-gray-600">Monto mínimo, cobertura y estado. Editar o restablecer a valores por defecto.</p>
        </div>
        <div class="p-6">
          <div id="delivery-loading" class="text-center py-8 text-gray-500">Cargando configuración de envío...</div>
          <div id="delivery-list-wrap" class="hidden overflow-x-auto">
            <table class="w-full min-w-[500px]">
              <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Monto mínimo (Bs)</th>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Cobertura (km)</th>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Envío gratis</th>
                  <th class="text-right py-3 px-4 text-sm font-semibold text-gray-700">Acciones</th>
                </tr>
              </thead>
              <tbody id="delivery-tbody">
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Lista de descuentos -->
      <div class="bg-white rounded-3xl border border-gray-200 shadow-md overflow-hidden mb-8">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div>
            <h2 class="text-xl font-bold text-gray-900">Lista de descuentos</h2>
            <p class="text-sm text-gray-600">Define alcance (tienda, marcas o productos), guarda y se actualizan precios en catálogo. Al aplicar, se guardan también los IDs de marca y producto para la página de ofertas (<code class="text-xs bg-gray-100 px-1 rounded">/products?filter=discount</code>). Editar o eliminar.</p>
          </div>
          <button
            type="button"
            id="new-discount-btn"
            class="px-5 py-2.5 bg-purple-600 text-white font-semibold rounded-xl hover:bg-purple-700 transition-all flex items-center gap-2 shrink-0"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Nuevo descuento
          </button>
        </div>
        <div class="p-6">
          <div id="discounts-loading" class="text-center py-8 text-gray-500">Cargando descuentos...</div>
          <div id="discounts-list-wrap" class="hidden overflow-x-auto">
            <table class="w-full min-w-[720px]">
              <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Nombre</th>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Alcance</th>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Valor</th>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Vigencia</th>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Estado</th>
                  <th class="text-left py-3 px-4 text-sm font-semibold text-gray-700">Usos</th>
                  <th class="text-right py-3 px-4 text-sm font-semibold text-gray-700">Acciones</th>
                </tr>
              </thead>
              <tbody id="discounts-tbody">
              </tbody>
            </table>
          </div>
          <div id="discounts-empty" class="hidden text-center py-8 text-gray-500">
            No hay descuentos. Crea uno con el botón "Nuevo descuento".
          </div>
        </div>
      </div>

      <!-- Métricas -->
      <div class="bg-white rounded-3xl border border-gray-200 shadow-md overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
          <h2 class="text-xl font-bold text-gray-900">Métricas</h2>
          <p class="text-sm text-gray-600">Pedidos con envío gratis, ticket promedio, fuera de cobertura y conversión</p>
        </div>
        <div class="p-6">
          <div id="metrics-loading" class="text-center py-8 text-gray-500">
            Cargando métricas...
          </div>
          <div id="metrics-grid" class="hidden">
            <!-- Pedidos con envío gratis -->
            <div class="bg-green-50 rounded-2xl p-6 border border-green-100">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl bg-green-100 flex items-center justify-center">
                  <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600">Pedidos con envío gratis</p>
                  <p id="metric-free-delivery" class="text-2xl font-bold text-gray-900">0</p>
                </div>
              </div>
            </div>

            <!-- Ticket promedio -->
            <div class="bg-purple-50 rounded-2xl p-6 border border-purple-100">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl bg-purple-100 flex items-center justify-center">
                  <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600">Ticket promedio</p>
                  <p id="metric-avg-ticket" class="text-2xl font-bold text-gray-900">Bs. 0</p>
                </div>
              </div>
            </div>

            <!-- Pedidos fuera de cobertura -->
            <div class="bg-amber-50 rounded-2xl p-6 border border-amber-100">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl bg-amber-100 flex items-center justify-center">
                  <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600">Pedidos fuera de cobertura</p>
                  <p id="metric-out-coverage" class="text-2xl font-bold text-gray-900">0</p>
                </div>
              </div>
            </div>

            <!-- Conversión "Te faltan X Bs" -->
            <div class="bg-blue-50 rounded-2xl p-6 border border-blue-100">
              <div class="flex items-center gap-3">
                <div class="w-12 h-12 rounded-xl bg-blue-100 flex items-center justify-center">
                  <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                  </svg>
                </div>
                <div>
                  <p class="text-sm text-gray-600">Conversión "Te faltan X Bs"</p>
                  <p id="metric-conversion" class="text-2xl font-bold text-gray-900">0</p>
                  <p class="text-xs text-gray-500 mt-0.5">Pedidos completados tras ver el mensaje</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modal Crear/Editar Descuento -->
  <div id="discount-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4" style="display: none;">
    <div class="bg-white rounded-2xl shadow-xl max-w-2xl w-full max-h-[90vh] overflow-y-auto">
      <div class="p-6 border-b border-gray-200 flex justify-between items-center">
        <h3 id="discount-modal-title" class="text-xl font-bold text-gray-900">Nuevo descuento</h3>
        <button type="button" id="discount-modal-close" class="text-gray-400 hover:text-gray-600 p-1">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <form id="discount-form" class="p-6 space-y-4">
        <input type="hidden" id="discount-id" value="" />
        <div>
          <label for="discount-name" class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
          <input type="text" id="discount-name" required class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="Ej. Verano 20%" />
        </div>
        <div>
          <label for="discount-type" class="block text-sm font-medium text-gray-700 mb-1">¿A quién aplica?</label>
          <select id="discount-type" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none">
            <option value="global">Toda la tienda (todos los productos)</option>
            <option value="brand">Por marca(s)</option>
            <option value="product">Por producto(s)</option>
            <option value="category">Por categoría (legacy)</option>
          </select>
          <p class="text-xs text-gray-500 mt-1">Al guardar se actualizan los precios en catálogo según el alcance elegido. Tras aplicar, Firestore guarda <strong>listingBrandIds</strong> y <strong>listingProductIds</strong> para mostrar marcas y productos en ofertas en la tienda.</p>
        </div>

        <div id="discount-scope-global-hint" class="rounded-xl border border-purple-100 bg-purple-50/70 px-4 py-3 text-sm text-gray-700">
          Se aplicará el descuento a <strong>todos los productos</strong> del catálogo.
        </div>

        <div id="discount-scope-brands-wrap" class="hidden space-y-2">
          <label class="block text-sm font-medium text-gray-700">Marcas en promoción</label>
          <p class="text-xs text-gray-500">Marca una o varias; el descuento afecta todos los productos de esas marcas.</p>
          <div id="discount-brands-loading" class="text-sm text-gray-500 py-2">Cargando marcas…</div>
          <div id="discount-brands-list" class="hidden max-h-52 overflow-y-auto rounded-xl border-2 border-gray-200 divide-y divide-gray-100"></div>
        </div>

        <div id="discount-scope-products-wrap" class="hidden space-y-2">
          <label class="block text-sm font-medium text-gray-700">Productos en promoción</label>
          <input type="search" id="discount-product-search" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="Buscar por nombre…" autocomplete="off" />
          <div id="discount-products-loading" class="text-sm text-gray-500 py-2">Cargando productos…</div>
          <div id="discount-products-list" class="hidden max-h-56 overflow-y-auto rounded-xl border-2 border-gray-200 divide-y divide-gray-100"></div>
        </div>

        <div id="discount-scope-category-wrap" class="hidden space-y-2">
          <label for="discount-category-slug" class="block text-sm font-medium text-gray-700">Slug de categoría</label>
          <input type="text" id="discount-category-slug" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="ej. dog, cat" />
          <p class="text-xs text-gray-500">Preferible usar marcas o productos; esto es compatibilidad con datos antiguos.</p>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="discount-value" class="block text-sm font-medium text-gray-700 mb-1">Valor</label>
            <input type="number" id="discount-value" required min="0" step="0.01" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="0" />
          </div>
          <div>
            <label for="discount-type-value" class="block text-sm font-medium text-gray-700 mb-1">Tipo de valor</label>
            <select id="discount-type-value" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none">
              <option value="percentage">Porcentaje (%)</option>
              <option value="fixed">Monto fijo (Bs)</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="discount-start" class="block text-sm font-medium text-gray-700 mb-1">Inicio</label>
            <input type="date" id="discount-start" required class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" />
          </div>
          <div>
            <label for="discount-end" class="block text-sm font-medium text-gray-700 mb-1">Fin</label>
            <input type="date" id="discount-end" required class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label for="discount-min-purchase" class="block text-sm font-medium text-gray-700 mb-1">Mín. compra (Bs)</label>
            <input type="number" id="discount-min-purchase" min="0" step="1" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="0" />
          </div>
          <div>
            <label for="discount-max-uses" class="block text-sm font-medium text-gray-700 mb-1">Máx. usos</label>
            <input type="number" id="discount-max-uses" min="0" step="1" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="Ilimitado" />
          </div>
        </div>
        <div class="flex items-center gap-2">
          <input type="checkbox" id="discount-active" checked class="w-4 h-4 text-purple-600 rounded focus:ring-purple-500" />
          <label for="discount-active" class="text-sm font-medium text-gray-700">Activo</label>
        </div>
        <div class="flex gap-3 pt-4">
          <button type="button" id="discount-form-cancel" class="flex-1 px-4 py-2.5 border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50">Cancelar</button>
          <button type="submit" id="discount-form-submit" class="flex-1 px-4 py-2.5 bg-purple-600 text-white font-semibold rounded-xl hover:bg-purple-700">Guardar y aplicar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Confirmar eliminar descuento -->
  <div id="delete-discount-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4" style="display: none;">
    <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6 text-center">
      <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-900 mb-2">¿Eliminar descuento?</h3>
      <p id="delete-discount-message" class="text-gray-600 mb-6">Esta acción no se puede deshacer.</p>
      <div class="flex gap-4">
        <button type="button" id="delete-discount-cancel" class="flex-1 px-6 py-3 border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50">Cancelar</button>
        <button type="button" id="delete-discount-confirm" class="flex-1 px-6 py-3 bg-red-600 text-white font-semibold rounded-xl hover:bg-red-700">Eliminar</button>
      </div>
    </div>
  </div>

  <!-- Modal Editar configuración de envío -->
  <div id="delivery-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4" style="display: none;">
    <div class="bg-white rounded-2xl shadow-xl max-w-lg w-full max-h-[90vh] overflow-y-auto">
      <div class="p-6 border-b border-gray-200 flex justify-between items-center">
        <h3 class="text-xl font-bold text-gray-900">Editar configuración de envío</h3>
        <button type="button" id="delivery-modal-close" class="text-gray-400 hover:text-gray-600 p-1">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>
      <form id="delivery-form" class="p-6 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="dl-min-purchase" class="block text-sm font-medium text-gray-700 mb-1">Monto mínimo (Bs)</label>
            <input type="number" id="dl-min-purchase" min="0" step="1" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="200" />
          </div>
          <div>
            <label for="dl-coverage" class="block text-sm font-medium text-gray-700 mb-1">Cobertura (km)</label>
            <input type="number" id="dl-coverage" min="0" step="0.5" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="5" />
          </div>
        </div>
        <div class="flex items-center gap-2 p-3 rounded-xl bg-gray-50 border border-gray-200">
          <input type="checkbox" id="dl-free-enabled" class="w-4 h-4 text-purple-600 rounded focus:ring-purple-500" />
          <label for="dl-free-enabled" class="text-sm font-medium text-gray-700">Envío gratis habilitado</label>
        </div>
        <div class="rounded-xl border border-purple-100 bg-purple-50/60 p-3 space-y-1">
          <p class="text-sm font-semibold text-gray-900">Mensajes y notificaciones</p>
          <p class="text-xs text-gray-600 leading-relaxed">
            Se guardan en la configuración de la tienda y los cambias desde aquí. Usa <code class="text-purple-700 bg-white/80 px-1 rounded">{'{amount}'}</code> (monto que falta) y opcionalmente <code class="text-purple-700 bg-white/80 px-1 rounded">{'{name}'}</code> (primer nombre si el cliente inició sesión) en los mensajes del carrito.
          </p>
        </div>
        <div>
          <label for="dl-message-te-faltan" class="block text-sm font-medium text-gray-700 mb-1">Mensaje «Te faltan X Bs»</label>
          <p class="text-xs text-gray-500 mb-1.5">Panel del carrito (icono): texto naranja si el subtotal aún no alcanza el mínimo.</p>
          <input type="text" id="dl-message-te-faltan" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="Te faltan {amount} Bs para envío gratis" />
        </div>
        <div>
          <label for="dl-message-fuera" class="block text-sm font-medium text-gray-700 mb-1">Mensaje fuera de cobertura</label>
          <p class="text-xs text-gray-500 mb-1.5">Checkout: cuando el punto de entrega queda fuera del radio (km) desde la tienda.</p>
          <input type="text" id="dl-message-fuera" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="Tu dirección está fuera de cobertura." />
        </div>
        <div>
          <label for="dl-message-gratis" class="block text-sm font-medium text-gray-700 mb-1">Mensaje envío gratis</label>
          <p class="text-xs text-gray-500 mb-1.5">Panel del carrito (verde) cuando el subtotal ya cumple el mínimo; en checkout (banner junto al mapa) cuando además la ubicación está en cobertura.</p>
          <input type="text" id="dl-message-gratis" class="w-full px-4 py-2 rounded-xl border-2 border-gray-200 focus:border-purple-400 focus:outline-none" placeholder="¡Felicidades! Tienes envío gratis" />
        </div>
        <div class="flex gap-3 pt-4">
          <button type="button" id="delivery-form-cancel" class="flex-1 px-4 py-2.5 border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50">Cancelar</button>
          <button type="submit" id="delivery-form-submit" class="flex-1 px-4 py-2.5 bg-purple-600 text-white font-semibold rounded-xl hover:bg-purple-700">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Confirmar eliminar configuración de envío -->
  <div id="delete-delivery-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center p-4" style="display: none;">
    <div class="bg-white rounded-2xl shadow-xl max-w-md w-full p-6 text-center">
      <div class="w-16 h-16 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-gray-900 mb-2">¿Restablecer configuración de envío?</h3>
      <p class="text-gray-600 mb-6">Se eliminará la configuración guardada y se usarán los valores por defecto (mín. Bs 200, 5 km, envío gratis activado).</p>
      <div class="flex gap-4">
        <button type="button" id="delete-delivery-cancel" class="flex-1 px-6 py-3 border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:bg-gray-50">Cancelar</button>
        <button type="button" id="delete-delivery-confirm" class="flex-1 px-6 py-3 bg-amber-600 text-white font-semibold rounded-xl hover:bg-amber-700">Restablecer</button>
      </div>
    </div>
  </div>

  <script>
    import { showAdminToast } from '../../lib/ui/adminSonnerToast';

    (function () {
      const metricsLoading = document.getElementById('metrics-loading');
      const metricsGrid = document.getElementById('metrics-grid');
      const metricFreeDelivery = document.getElementById('metric-free-delivery');
      const metricAvgTicket = document.getElementById('metric-avg-ticket');
      const metricOutCoverage = document.getElementById('metric-out-coverage');
      const metricConversion = document.getElementById('metric-conversion');

      async function loadMetrics() {
        if (!metricsLoading || !metricsGrid) return;
        try {
          const { getAllOrders } = await import('../../lib/db/orders');
          const { data: orders } = await getAllOrders();
          const list = orders || [];

          const withFreeDelivery = list.filter((o: any) => o.shippingCost === 0 || o.freeDelivery === true);
          const totalSum = list.reduce((acc: number, o: any) => acc + (o.total ?? 0), 0);
          const avgTicket = list.length ? totalSum / list.length : 0;
          const outOfCoverage = list.filter((o: any) => o.outOfCoverage === true);
          const conversionTeFaltan = list.filter((o: any) => o.sawTeFaltanMessage === true);

          if (metricFreeDelivery) metricFreeDelivery.textContent = String(withFreeDelivery.length);
          if (metricAvgTicket) metricAvgTicket.textContent = 'Bs. ' + avgTicket.toFixed(2);
          if (metricOutCoverage) metricOutCoverage.textContent = String(outOfCoverage.length);
          if (metricConversion) metricConversion.textContent = String(conversionTeFaltan.length);

          metricsLoading.classList.add('hidden');
          metricsGrid.classList.remove('hidden');
          metricsGrid.className = 'grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6';
        } catch (e) {
          console.error('Error loading metrics:', e);
          metricsLoading.textContent = 'Error al cargar métricas.';
        }
      }

      // ---------- Lista de envío gratis ----------
      const deliveryLoading = document.getElementById('delivery-loading');
      const deliveryListWrap = document.getElementById('delivery-list-wrap');
      const deliveryTbody = document.getElementById('delivery-tbody');
      const deliveryModal = document.getElementById('delivery-modal');
      const deliveryModalClose = document.getElementById('delivery-modal-close');
      const deliveryForm = document.getElementById('delivery-form') as HTMLFormElement;
      const deliveryFormCancel = document.getElementById('delivery-form-cancel');
      const deleteDeliveryModal = document.getElementById('delete-delivery-modal');
      const deleteDeliveryCancel = document.getElementById('delete-delivery-cancel');
      const deleteDeliveryConfirm = document.getElementById('delete-delivery-confirm');

      function openDeliveryModal() {
        if (!deliveryModal || !deliveryForm) return;
        (async () => {
          try {
            const { getDeliverySettings } = await import('../../lib/db/storeSettings');
            const result = await getDeliverySettings();
            if (result.error) throw result.error;
            const s = result.data;
            if (s) {
              (document.getElementById('dl-min-purchase') as HTMLInputElement).value = String(s.minPurchaseAmount ?? 200);
              (document.getElementById('dl-coverage') as HTMLInputElement).value = String(s.coverageRadiusKm ?? 5);
              (document.getElementById('dl-free-enabled') as HTMLInputElement).checked = s.freeDeliveryEnabled !== false;
              (document.getElementById('dl-message-te-faltan') as HTMLInputElement).value = s.messageTeFaltan ?? 'Te faltan {amount} Bs para envío gratis';
              (document.getElementById('dl-message-fuera') as HTMLInputElement).value = s.messageFueraCobertura ?? 'Tu dirección está fuera de nuestra zona de cobertura.';
              (document.getElementById('dl-message-gratis') as HTMLInputElement).value = s.messageEnvioGratis ?? '¡Felicidades! Tienes envío gratis';
            }
          } catch (e) {
            console.error('Error loading delivery for modal:', e);
          }
          deliveryModal.classList.remove('hidden');
          deliveryModal.classList.add('flex');
          deliveryModal.style.display = 'flex';
        })();
      }

      function closeDeliveryModal() {
        if (!deliveryModal) return;
        deliveryModal.classList.add('hidden');
        deliveryModal.classList.remove('flex');
        deliveryModal.style.display = 'none';
      }

      function openDeleteDeliveryModal() {
        if (!deleteDeliveryModal) return;
        deleteDeliveryModal.classList.remove('hidden');
        deleteDeliveryModal.classList.add('flex');
        deleteDeliveryModal.style.display = 'flex';
      }

      function closeDeleteDeliveryModal() {
        if (!deleteDeliveryModal) return;
        deleteDeliveryModal.classList.add('hidden');
        deleteDeliveryModal.classList.remove('flex');
        deleteDeliveryModal.style.display = 'none';
      }

      async function loadDeliveryList() {
        if (!deliveryLoading || !deliveryListWrap || !deliveryTbody) return;
        try {
          const { getDeliverySettings } = await import('../../lib/db/storeSettings');
          const result = await getDeliverySettings();
          if (result.error) throw result.error;
          const s = result.data;
          deliveryLoading.classList.add('hidden');
          deliveryListWrap.classList.remove('hidden');
          const enabled = s?.freeDeliveryEnabled !== false;
          const min = s?.minPurchaseAmount ?? 200;
          const km = s?.coverageRadiusKm ?? 5;
          deliveryTbody.innerHTML = `
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="py-3 px-4 font-medium text-gray-900">${min}</td>
              <td class="py-3 px-4 text-sm text-gray-700">${km}</td>
              <td class="py-3 px-4">
                <span class="px-2 py-0.5 rounded-full text-xs font-medium ${enabled ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600'}">${enabled ? 'Habilitado' : 'Deshabilitado'}</span>
              </td>
              <td class="py-3 px-4 text-right">
                <button type="button" class="edit-delivery-btn px-2 py-1 text-blue-600 hover:bg-blue-50 rounded-lg text-sm font-medium">Editar</button>
                <button type="button" class="delete-delivery-btn px-2 py-1 text-red-600 hover:bg-red-50 rounded-lg text-sm font-medium">Eliminar</button>
              </td>
            </tr>`;
          deliveryTbody.querySelector('.edit-delivery-btn')?.addEventListener('click', openDeliveryModal);
          deliveryTbody.querySelector('.delete-delivery-btn')?.addEventListener('click', openDeleteDeliveryModal);
        } catch (e) {
          console.error('Error loading delivery list:', e);
          deliveryLoading.textContent = 'Error al cargar configuración de envío.';
        }
      }

      deliveryModalClose?.addEventListener('click', closeDeliveryModal);
      deliveryFormCancel?.addEventListener('click', closeDeliveryModal);
      deliveryModal?.addEventListener('click', (e) => { if (e.target === deliveryModal) closeDeliveryModal(); });
      deliveryForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const minPurchase = Number((document.getElementById('dl-min-purchase') as HTMLInputElement).value) || 0;
        const coverage = Number((document.getElementById('dl-coverage') as HTMLInputElement).value) || 0;
        const freeEnabled = (document.getElementById('dl-free-enabled') as HTMLInputElement).checked;
        const msgTeFaltan = (document.getElementById('dl-message-te-faltan') as HTMLInputElement).value.trim();
        const msgFuera = (document.getElementById('dl-message-fuera') as HTMLInputElement).value.trim();
        const msgGratis = (document.getElementById('dl-message-gratis') as HTMLInputElement).value.trim();
        const submitBtn = document.getElementById('delivery-form-submit') as HTMLButtonElement;
        if (submitBtn) submitBtn.disabled = true;
        try {
          const { updateDeliverySettings } = await import('../../lib/db/storeSettings');
          const res = await updateDeliverySettings({
            minPurchaseAmount: minPurchase,
            coverageRadiusKm: coverage,
            freeDeliveryEnabled: freeEnabled,
            messageTeFaltan: msgTeFaltan || undefined,
            messageFueraCobertura: msgFuera || undefined,
            messageEnvioGratis: msgGratis || undefined,
          });
          if (res.error) throw res.error;
          showAdminToast('Configuración de envío guardada.', 'success');
          closeDeliveryModal();
          loadDeliveryList();
        } catch (err: any) {
          showAdminToast(err?.message || 'Error al guardar.', 'error');
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });

      deleteDeliveryCancel?.addEventListener('click', closeDeleteDeliveryModal);
      deleteDeliveryConfirm?.addEventListener('click', async () => {
        const btn = deleteDeliveryConfirm as HTMLButtonElement;
        btn.disabled = true;
        try {
          const { deleteDeliverySettings } = await import('../../lib/db/storeSettings');
          const res = await deleteDeliverySettings();
          if (res.error) throw res.error;
          showAdminToast('Configuración restablecida a valores por defecto.', 'success');
          closeDeleteDeliveryModal();
          loadDeliveryList();
        } catch (err: any) {
          showAdminToast(err?.message || 'Error al eliminar.', 'error');
        } finally {
          btn.disabled = false;
        }
      });
      deleteDeliveryModal?.addEventListener('click', (e) => { if (e.target === deleteDeliveryModal) closeDeleteDeliveryModal(); });

      // Alias por si algo (p. ej. caché) sigue llamando a loadSettings
      function loadSettings() {
        loadDeliveryList();
      }

      loadDeliveryList();
      loadMetrics();

      // ---------- Descuentos ----------
      const discountsLoading = document.getElementById('discounts-loading');
      const discountsListWrap = document.getElementById('discounts-list-wrap');
      const discountsTbody = document.getElementById('discounts-tbody');
      const discountsEmpty = document.getElementById('discounts-empty');
      const newDiscountBtn = document.getElementById('new-discount-btn');
      const discountModal = document.getElementById('discount-modal');
      const discountModalTitle = document.getElementById('discount-modal-title');
      const discountModalClose = document.getElementById('discount-modal-close');
      const discountForm = document.getElementById('discount-form') as HTMLFormElement;
      const discountIdInput = document.getElementById('discount-id') as HTMLInputElement;
      const discountFormCancel = document.getElementById('discount-form-cancel');
      const deleteDiscountModal = document.getElementById('delete-discount-modal');
      const deleteDiscountMessage = document.getElementById('delete-discount-message');
      const deleteDiscountCancel = document.getElementById('delete-discount-cancel');
      const deleteDiscountConfirm = document.getElementById('delete-discount-confirm');

      const brandSelection = new Set<string>();
      const productSelection = new Set<string>();

      function formatDiscountDate(v: any): string {
        if (!v) return '-';
        const d = v?.toDate ? v.toDate() : new Date(v);
        return isNaN(d.getTime()) ? '-' : d.toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric' });
      }

      function toDateInputValue(v: any): string {
        if (!v) return '';
        const d = v?.toDate ? v.toDate() : new Date(v);
        if (isNaN(d.getTime())) return '';
        return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
      }

      function discountScopeLabel(d: any): string {
        const t = d.type;
        const nTargets = (d.targetIds && d.targetIds.length) || (d.targetId ? 1 : 0);
        if (t === 'global') return 'Toda la tienda';
        if (t === 'brand') return nTargets ? `${nTargets} marca(s)` : 'Sin marcas';
        if (t === 'product') return nTargets ? `${nTargets} producto(s)` : 'Sin productos';
        if (t === 'category') return 'Categoría';
        return String(t || '—');
      }

      function renderDiscountsList(list: any[]) {
        if (!discountsTbody || !discountsLoading || !discountsListWrap || !discountsEmpty) return;
        discountsLoading.classList.add('hidden');
        if (list.length === 0) {
          discountsListWrap.classList.add('hidden');
          discountsEmpty.classList.remove('hidden');
          discountsTbody.innerHTML = '';
          return;
        }
        discountsEmpty.classList.add('hidden');
        discountsListWrap.classList.remove('hidden');
        discountsTbody.innerHTML = list.map((d: any) => {
          const valor = d.discountType === 'percentage' ? (d.discountValue || 0) + '%' : 'Bs. ' + (d.discountValue || 0);
          const usos = d.maxUses != null ? (d.currentUses || 0) + ' / ' + d.maxUses : (d.currentUses || 0) + ' / ∞';
          return `
            <tr class="border-b border-gray-100 hover:bg-gray-50">
              <td class="py-3 px-4 font-medium text-gray-900">${escapeHtml(d.name || '')}</td>
              <td class="py-3 px-4 text-sm text-gray-700">${escapeHtml(discountScopeLabel(d))}</td>
              <td class="py-3 px-4 text-sm font-semibold text-purple-600">${valor}</td>
              <td class="py-3 px-4 text-sm text-gray-600">${formatDiscountDate(d.startDate)} - ${formatDiscountDate(d.endDate)}</td>
              <td class="py-3 px-4">
                <span class="px-2 py-0.5 rounded-full text-xs font-medium ${d.isActive ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600'}">${d.isActive ? 'Activo' : 'Inactivo'}</span>
              </td>
              <td class="py-3 px-4 text-sm text-gray-600">${usos}</td>
              <td class="py-3 px-4 text-right">
                <button type="button" class="edit-discount-btn px-2 py-1 text-blue-600 hover:bg-blue-50 rounded-lg text-sm font-medium" data-discount-id="${escapeHtml(d.id)}">Editar</button>
                <button type="button" class="delete-discount-btn px-2 py-1 text-red-600 hover:bg-red-50 rounded-lg text-sm font-medium" data-discount-id="${escapeHtml(d.id)}" data-discount-name="${escapeHtml(d.name || '')}">Eliminar</button>
              </td>
            </tr>`;
        }).join('');

        discountsTbody.querySelectorAll('.edit-discount-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).getAttribute('data-discount-id');
            if (id) openDiscountModal(id);
          });
        });
        discountsTbody.querySelectorAll('.delete-discount-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).getAttribute('data-discount-id');
            const name = (btn as HTMLElement).getAttribute('data-discount-name') || '';
            if (id) openDeleteDiscountModal(id, name);
          });
        });
      }

      function escapeHtml(s: string): string {
        const div = document.createElement('div');
        div.textContent = s;
        return div.innerHTML;
      }

      async function loadDiscounts() {
        try {
          const { getDiscounts } = await import('../../lib/db/discounts');
          const { data } = await getDiscounts();
          const list = data || [];
          renderDiscountsList(list);
        } catch (e) {
          console.error('Error loading discounts:', e);
          if (discountsLoading) discountsLoading.textContent = 'Error al cargar descuentos.';
        }
      }

      function updateDiscountScopeVisibility() {
        const type = (document.getElementById('discount-type') as HTMLSelectElement)?.value || 'global';
        document.getElementById('discount-scope-global-hint')?.classList.toggle('hidden', type !== 'global');
        document.getElementById('discount-scope-brands-wrap')?.classList.toggle('hidden', type !== 'brand');
        document.getElementById('discount-scope-products-wrap')?.classList.toggle('hidden', type !== 'product');
        document.getElementById('discount-scope-category-wrap')?.classList.toggle('hidden', type !== 'category');
      }

      function getSelectedTargetIds(): string[] {
        const type = (document.getElementById('discount-type') as HTMLSelectElement).value;
        if (type === 'brand') return [...brandSelection];
        if (type === 'product') return [...productSelection];
        return [];
      }

      async function ensureBrandsRendered(selectedIds: string[]) {
        const loading = document.getElementById('discount-brands-loading');
        const list = document.getElementById('discount-brands-list');
        if (!loading || !list) return;
        selectedIds.forEach((id) => brandSelection.add(id));
        loading.classList.remove('hidden');
        list.classList.add('hidden');
        const { getBrands } = await import('../../lib/db/brands');
        const { data } = await getBrands();
        const brands = (data || []).map((b: any) => ({ id: b.id, name: b.name }));
        const sel = brandSelection;
        list.innerHTML = brands
          .map(
            (b: { id: string; name: string }) => `
          <label class="flex items-center gap-3 px-3 py-2 hover:bg-gray-50 cursor-pointer">
            <input type="checkbox" value="${escapeHtml(b.id)}" class="discount-brand-cb w-4 h-4 rounded text-purple-600" ${sel.has(b.id) ? 'checked' : ''} />
            <span class="text-sm text-gray-800">${escapeHtml(b.name)}</span>
          </label>`
          )
          .join('');
        loading.classList.add('hidden');
        list.classList.remove('hidden');
      }

      async function ensureProductsRendered(selectedIds: string[], searchQ: string) {
        const loading = document.getElementById('discount-products-loading');
        const plist = document.getElementById('discount-products-list');
        if (!loading || !plist) return;
        selectedIds.forEach((id) => productSelection.add(id));
        loading.classList.remove('hidden');
        plist.classList.add('hidden');
        const { getProducts } = await import('../../lib/db/products');
        const { data } = await getProducts({});
        const all = (data || []).map((p: any) => ({ id: p.id, name: p.name || p.id }));
        const q = searchQ.trim().toLowerCase();
        const filtered = q ? all.filter((p: { name: string }) => p.name.toLowerCase().includes(q)) : all;
        const sel = productSelection;
        plist.innerHTML = filtered
          .map(
            (p: { id: string; name: string }) => `
          <label class="flex items-center gap-3 px-3 py-2 hover:bg-gray-50 cursor-pointer">
            <input type="checkbox" value="${escapeHtml(p.id)}" class="discount-product-cb w-4 h-4 rounded text-purple-600" ${sel.has(p.id) ? 'checked' : ''} />
            <span class="text-sm text-gray-800">${escapeHtml(p.name)}</span>
          </label>`
          )
          .join('');
        loading.classList.add('hidden');
        plist.classList.remove('hidden');
      }

      discountModal?.addEventListener('change', (ev) => {
        const t = ev.target as HTMLInputElement;
        if (t?.type !== 'checkbox') return;
        if (t.classList.contains('discount-brand-cb')) {
          if (t.checked) brandSelection.add(t.value);
          else brandSelection.delete(t.value);
        }
        if (t.classList.contains('discount-product-cb')) {
          if (t.checked) productSelection.add(t.value);
          else productSelection.delete(t.value);
        }
      });

      async function refreshDiscountPickers(selectedIds: string[]) {
        const type = (document.getElementById('discount-type') as HTMLSelectElement).value;
        updateDiscountScopeVisibility();
        if (type === 'brand') await ensureBrandsRendered(selectedIds);
        if (type === 'product') {
          const search = (document.getElementById('discount-product-search') as HTMLInputElement)?.value || '';
          await ensureProductsRendered(selectedIds, search);
        }
      }

      function openDiscountModal(editId?: string) {
        if (!discountModal || !discountForm) return;
        const typeSel = document.getElementById('discount-type') as HTMLSelectElement;
        const catSlug = document.getElementById('discount-category-slug') as HTMLInputElement;

        if (editId) {
          discountModalTitle!.textContent = 'Editar descuento';
          discountIdInput.value = editId;
          (async () => {
            const { getDiscountById } = await import('../../lib/db/discounts');
            const { data: d } = await getDiscountById(editId);
            if (d) {
              (document.getElementById('discount-name') as HTMLInputElement).value = d.name || '';
              typeSel.value = ['global', 'brand', 'product', 'category'].includes(d.type) ? d.type : 'global';
              (document.getElementById('discount-value') as HTMLInputElement).value = String(d.discountValue ?? '');
              (document.getElementById('discount-type-value') as HTMLSelectElement).value = d.discountType || 'percentage';
              (document.getElementById('discount-start') as HTMLInputElement).value = toDateInputValue(d.startDate);
              (document.getElementById('discount-end') as HTMLInputElement).value = toDateInputValue(d.endDate);
              (document.getElementById('discount-min-purchase') as HTMLInputElement).value = d.minPurchaseAmount != null ? String(d.minPurchaseAmount) : '';
              (document.getElementById('discount-max-uses') as HTMLInputElement).value = d.maxUses != null ? String(d.maxUses) : '';
              (document.getElementById('discount-active') as HTMLInputElement).checked = d.isActive !== false;
              if (catSlug) catSlug.value = d.targetId || '';

              const tids =
                d.targetIds && d.targetIds.length > 0
                  ? [...d.targetIds]
                  : d.targetId
                    ? [d.targetId]
                    : [];
              brandSelection.clear();
              productSelection.clear();
              if (d.type === 'brand') tids.forEach((x) => brandSelection.add(x));
              if (d.type === 'product') tids.forEach((x) => productSelection.add(x));
              updateDiscountScopeVisibility();
              await refreshDiscountPickers(tids);
            }
          })();
        } else {
          discountModalTitle!.textContent = 'Nuevo descuento';
          discountIdInput.value = '';
          discountForm.reset();
          brandSelection.clear();
          productSelection.clear();
          (document.getElementById('discount-active') as HTMLInputElement).checked = true;
          const today = new Date().toISOString().slice(0, 10);
          (document.getElementById('discount-start') as HTMLInputElement).value = today;
          (document.getElementById('discount-end') as HTMLInputElement).value = today;
          if (catSlug) catSlug.value = '';
          typeSel.value = 'global';
          updateDiscountScopeVisibility();
          (async () => {
            await refreshDiscountPickers([]);
          })();
        }
        discountModal.classList.remove('hidden');
        discountModal.classList.add('flex');
        discountModal.style.display = 'flex';
      }

      function closeDiscountModal() {
        if (!discountModal) return;
        discountModal.classList.add('hidden');
        discountModal.classList.remove('flex');
        discountModal.style.display = 'none';
      }

      function openDeleteDiscountModal(id: string, name: string) {
        if (!deleteDiscountModal || !deleteDiscountConfirm) return;
        deleteDiscountMessage!.textContent = name ? `¿Eliminar el descuento "${name}"? Esta acción no se puede deshacer.` : '¿Eliminar este descuento? Esta acción no se puede deshacer.';
        deleteDiscountConfirm.setAttribute('data-discount-id', id);
        deleteDiscountModal.classList.remove('hidden');
        deleteDiscountModal.classList.add('flex');
        deleteDiscountModal.style.display = 'flex';
      }

      function closeDeleteDiscountModal() {
        if (!deleteDiscountModal) return;
        deleteDiscountModal.classList.add('hidden');
        deleteDiscountModal.classList.remove('flex');
        deleteDiscountModal.style.display = 'none';
      }

      newDiscountBtn?.addEventListener('click', () => openDiscountModal());
      discountModalClose?.addEventListener('click', closeDiscountModal);
      discountFormCancel?.addEventListener('click', closeDiscountModal);

      document.getElementById('discount-type')?.addEventListener('change', () => {
        brandSelection.clear();
        productSelection.clear();
        refreshDiscountPickers([]);
      });

      document.getElementById('discount-product-search')?.addEventListener('input', () => {
        refreshDiscountPickers([...productSelection]);
      });

      discountForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = discountIdInput.value.trim();
        const name = (document.getElementById('discount-name') as HTMLInputElement).value.trim();
        const type = (document.getElementById('discount-type') as HTMLSelectElement).value as any;
        const discountValue = Number((document.getElementById('discount-value') as HTMLInputElement).value) || 0;
        const discountTypeVal = (document.getElementById('discount-type-value') as HTMLSelectElement).value as any;
        const startDate = (document.getElementById('discount-start') as HTMLInputElement).value;
        const endDate = (document.getElementById('discount-end') as HTMLInputElement).value;
        const minPurchaseAmount = (document.getElementById('discount-min-purchase') as HTMLInputElement).value;
        const maxUses = (document.getElementById('discount-max-uses') as HTMLInputElement).value;
        const isActive = (document.getElementById('discount-active') as HTMLInputElement).checked;
        const start = startDate ? new Date(startDate) : new Date();
        const end = endDate ? new Date(endDate) : new Date();

        let targetIds: string[] | null = null;
        let targetId: string | null = null;
        if (type === 'brand' || type === 'product') {
          targetIds = getSelectedTargetIds();
          targetId = targetIds.length === 1 ? targetIds[0] : null;
          if (targetIds.length === 0) {
            showAdminToast('Selecciona al menos una marca o un producto.', 'error');
            return;
          }
        } else if (type === 'category') {
          const slug = (document.getElementById('discount-category-slug') as HTMLInputElement).value.trim();
          if (!slug) {
            showAdminToast('Indica el slug de categoría.', 'error');
            return;
          }
          targetId = slug;
          targetIds = null;
        } else {
          targetIds = null;
          targetId = null;
        }

        const submitBtn = document.getElementById('discount-form-submit') as HTMLButtonElement;
        if (submitBtn) submitBtn.disabled = true;
        try {
          const { updateDiscount, createDiscount, applyDiscountToProducts } = await import('../../lib/db/discounts');
          let discountDocId = id;

          if (id) {
            const res = await updateDiscount(id, {
              name,
              type,
              targetId,
              targetIds,
              discountValue,
              discountType: discountTypeVal,
              startDate: start,
              endDate: end,
              isActive,
              minPurchaseAmount: minPurchaseAmount ? Number(minPurchaseAmount) : undefined,
              maxUses: maxUses ? Number(maxUses) : undefined,
            });
            if (res.error) throw res.error;
          } else {
            const res = await createDiscount({
              name,
              type,
              targetId,
              targetIds,
              discountValue,
              discountType: discountTypeVal,
              startDate: start,
              endDate: end,
              isActive,
              minPurchaseAmount: minPurchaseAmount ? Number(minPurchaseAmount) : undefined,
              maxUses: maxUses ? Number(maxUses) : undefined,
            });
            if (res.error) throw res.error;
            discountDocId = res.id || '';
          }

          if (!discountDocId) throw new Error('ID de descuento no disponible');

          const applyRes = await applyDiscountToProducts(discountDocId);
          if (!applyRes.success) {
            const msg = applyRes.error?.message || '';
            const listingSaved = msg.includes('Se guardaron igualmente');
            showAdminToast(
              listingSaved ? msg : 'Configuración guardada, pero no se pudo aplicar a productos: ' + msg,
              listingSaved ? 'info' : 'error'
            );
          } else {
            const n = applyRes.appliedCount ?? 0;
            showAdminToast(
              id ? `Descuento actualizado. Precios aplicados en ${n} producto(s).` : `Descuento creado. Precios aplicados en ${n} producto(s).`,
              'success'
            );
          }

          closeDiscountModal();
          loadDiscounts();
        } catch (err: any) {
          showAdminToast(err?.message || 'Error al guardar.', 'error');
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });

      deleteDiscountCancel?.addEventListener('click', closeDeleteDiscountModal);
      deleteDiscountConfirm?.addEventListener('click', async () => {
        const id = deleteDiscountConfirm?.getAttribute('data-discount-id');
        if (!id || !deleteDiscountConfirm) return;
        const btn = deleteDiscountConfirm as HTMLButtonElement;
        btn.disabled = true;
        try {
          const { deleteDiscount } = await import('../../lib/db/discounts');
          const res = await deleteDiscount(id);
          if (res.error) throw res.error;
          showAdminToast('Descuento eliminado.', 'success');
          closeDeleteDiscountModal();
          loadDiscounts();
        } catch (err: any) {
          showAdminToast(err?.message || 'Error al eliminar.', 'error');
        } finally {
          btn.disabled = false;
        }
      });

      discountModal?.addEventListener('click', (e) => { if (e.target === discountModal) closeDiscountModal(); });
      deleteDiscountModal?.addEventListener('click', (e) => { if (e.target === deleteDiscountModal) closeDeleteDiscountModal(); });

      loadDiscounts();
    })();
  </script>
</Layout>
