      // Función para cargar marcas de una categoría (carga bajo demanda)
      async function loadBrandsForCategory(categoryId: string): Promise<any[]> {
        // Si ya están en caché, retornarlas
        if (brandsCache.has(categoryId)) {
          return brandsCache.get(categoryId) || [];
        }

        // Si ya se cargaron antes, retornar del caché
        if (loadedBrands.has(categoryId)) {
          return brandsCache.get(categoryId) || [];
        }

        console.log(`🏷️ Cargando marcas para categoría ${categoryId}...`);
        
        try {
          // Importar función de marcas
          const { getBrands } = await import('../lib/db/brands');
          const brandsResult = await getBrands();
          
          // Filtrar marcas por categoría
          const categoryBrands = (brandsResult.data || []).filter((brand: any) => 
            brand.categoryId === categoryId && brand.status === 'Activo'
          );

          // Guardar en caché
          brandsCache.set(categoryId, categoryBrands);
          loadedBrands.add(categoryId);
          
          // Optimizar estructura de datos: actualizar Maps y contadores
          const brandIds: string[] = [];
          categoryBrands.forEach((brand: any) => {
            // Actualizar brandMap para búsquedas O(1)
            brandMap.set(brand.id, brand);
            
            // Actualizar allBrandsData (sin duplicados)
            if (!allBrandsData.find((b: any) => b.id === brand.id)) {
              allBrandsData.push(brand);
            }
            
            brandIds.push(brand.id);
          });
          
          // Pre-calcular relación: marcas por categoría
          brandsByCategoryMap.set(categoryId, brandIds);
          categoryBrandCounts.set(categoryId, categoryBrands.length);

          console.log(`✅ Marcas cargadas para categoría ${categoryId}:`, categoryBrands.length);
          console.log(`   Contador pre-calculado: ${categoryBrands.length} marcas`);
          
          // Cachear marcas en Service Worker para acceso offline
          if (typeof window !== 'undefined' && (window as any).cacheData) {
            (window as any).cacheData(`brands-${categoryId}`, categoryBrands);
          }
          
          return categoryBrands;
        } catch (error) {
          console.error(`❌ Error cargando marcas para categoría ${categoryId}:`, error);
          return [];
        }
      }

