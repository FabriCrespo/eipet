      // Función para cargar productos de una marca (carga bajo demanda)
      async function loadProductsForBrand(brandId: string): Promise<any[]> {
        // Si ya están en caché, retornarlos
        if (productsCache.has(brandId)) {
          return productsCache.get(brandId) || [];
        }

        // Si ya se cargaron antes, retornar del caché
        if (loadedProducts.has(brandId)) {
          return productsCache.get(brandId) || [];
        }

        console.log(`📦 Cargando productos para marca ${brandId}...`);
        
        try {
          // Importar función de productos
          const { getProducts } = await import('../lib/db/products');
          
          // Crear mapas para búsqueda rápida
          const categoryMap = new Map(allCategoriesData.map((c: any) => [c.id, c]));
          const brandMap = new Map(allBrandsData.map((b: any) => [b.id, b]));

          // Función para mapear animalType a slug
          function getCategorySlug(categoryData: any): string {
            if (!categoryData) return 'all';
            if (categoryData.slug) return categoryData.slug;
            if (categoryData.animalType === 'Perro') return 'dog';
            if (categoryData.animalType === 'Gato') return 'cat';
            return 'all';
          }

          // Productos activos de esta marca (query en Firestore; menos lecturas que traer todo el catálogo)
          let productsResult: { data: any[]; error?: Error | null };
          let brandProducts: any[];

          try {
            productsResult = await getProducts({ brand: brandId, status: 'active' });
            const errCode = productsResult.error && (productsResult.error as { code?: string }).code;
            const rows = productsResult.data || [];
            const useFullCatalogFallback =
              errCode === 'failed-precondition' ||
              errCode === 'unavailable' ||
              (!!productsResult.error && rows.length === 0);

            if (!useFullCatalogFallback) {
              brandProducts = rows;
            } else {
              console.log(
                '[EIPET] Query brand+status no disponible o vacía con error; fallback a todos los activos + filtro por marca.'
              );
              productsResult = await getProducts({ status: 'active' });

              if (!productsResult.data || productsResult.data.length === 0 || productsResult.error) {
                console.log('⚠️ No se obtuvieron productos con status="active", intentando sin filtro...');
                const allProductsResult = await getProducts();

                if (allProductsResult.data && allProductsResult.data.length > 0) {
                  productsResult = {
                    data: allProductsResult.data.filter((p: any) => p.status === 'active'),
                    error: allProductsResult.error,
                  };
                } else {
                  productsResult = allProductsResult;
                }
              }

              brandProducts = (productsResult.data || []).filter(
                (p: any) => String(p.brand || '') === String(brandId)
              );
            }
          } catch (error) {
            console.error('❌ Error al obtener productos:', error);
            const allProductsResult = await getProducts();
            if (allProductsResult.data && allProductsResult.data.length > 0) {
              productsResult = {
                data: allProductsResult.data.filter((p: any) => p.status === 'active'),
                error: allProductsResult.error,
              };
            } else {
              productsResult = { data: [], error: error as Error };
            }
            brandProducts = (productsResult.data || []).filter(
              (p: any) => String(p.brand || '') === String(brandId)
            );
          }

          // Mapear productos al formato esperado
          let mappedProducts = brandProducts.map((p: any) => {
            const categoryData = categoryMap.get(p.category);
            const brandData = brandMap.get(p.brand);

            let originalPrice = p.originalPrice || null;
            if (p.discount > 0 && !originalPrice) {
              if (p.discountType === 'percentage') {
                originalPrice = Math.round((p.price * 100) / (100 - p.discount) * 100) / 100;
              }
            }

            const mappedProduct = {
              id: p.id,
              name: p.name || '',
              brand: p.brand || '',
              brandId: p.brand || '',
              brandName: brandData?.name || 'Sin marca',
              category: getCategorySlug(categoryData),
              categoryId: p.category,
              type: p.type || 'food',
              price: p.price || 0,
              originalPrice: originalPrice,
              discount: p.discount || 0,
              discountType: p.discountType || 'percentage',
              image: p.image || '',
              lifeStage: normalizeLifeStageField(String(p.lifeStage || '')) || inferLifeStageFromName(p.name || '') || '',
              breedSize: normalizeBreedSizeField(String(p.breedSize || '')) || inferBreedSizeFromName(p.name || '') || '',
              weight: p.weight || null,
              description: p.description || '',
              stock: p.stock || 0,
              minStock: p.minStock || 5,
              status: p.status || 'active',
              tags: p.tags || []
            };
            
            return mappedProduct;
          });

          if (discountFilterMode) {
            mappedProducts = mappedProducts.filter((p: any) => (p.discount || 0) > 0);
          }

          // Guardar en caché
          productsCache.set(brandId, mappedProducts);
          loadedProducts.add(brandId);
          
          // Optimizar estructura de datos: actualizar Maps y contadores
          const productIds: string[] = [];
          mappedProducts.forEach((product: any) => {
            // Actualizar productMap para búsquedas O(1)
            productMap.set(product.id, product);
            
            // Actualizar allProducts (sin duplicados)
            if (!allProducts.find((p: any) => p.id === product.id)) {
              allProducts.push(product);
            }
            
            productIds.push(product.id);
          });
          
          // Pre-calcular relación: productos por marca
          productsByBrandMap.set(brandId, productIds);
          brandProductCounts.set(brandId, mappedProducts.length);

          console.log(`✅ Productos cargados para marca ${brandId}:`, mappedProducts.length);
          console.log(`   Contador pre-calculado: ${mappedProducts.length} productos`);
          
          // Cachear productos en Service Worker para acceso offline
          if (typeof window !== 'undefined' && (window as any).cacheData) {
            (window as any).cacheData(`products-${brandId}`, mappedProducts);
          }
          
          return mappedProducts;
        } catch (error) {
          console.error(`❌ Error cargando productos para marca ${brandId}:`, error);
          return [];
        }
      }

      // Función para filtrar productos por brand ID (ahora usa caché)
      function filterProductsByBrand(brandId: string): any[] {
        // Si están en caché, usarlos directamente
        if (productsCache.has(brandId)) {
          return productsCache.get(brandId) || [];
        }
        
        // Si no están en caché, filtrar de allProducts (fallback)
        console.log(`🔍 Filtrando productos por brand ID: "${brandId}"`);
        console.log(`📊 Total de productos disponibles en allProducts: ${allProducts.length}`);
        
        if (allProducts.length === 0) {
          console.error('❌ ERROR: allProducts está vacío. Los productos no se cargaron correctamente.');
          return [];
        }
        
        // Mostrar todos los productos y sus brand IDs para debug
        console.log('🔍 Todos los productos y sus brand IDs:');
        allProducts.forEach((p: any, index: number) => {
          console.log(`  ${index + 1}. ID: ${p.id}, Nombre: "${p.name}", brand: "${p.brand}" (tipo: ${typeof p.brand}), brandId: "${p.brandId}" (tipo: ${typeof p.brandId}), status: "${p.status}"`);
        });
        
        const filtered = allProducts.filter((product: any) => {
          // Usar brandId si existe, sino usar brand
          const productBrandId = String(product.brandId || product.brand || '').trim();
          const targetBrandId = String(brandId).trim();
          const statusMatch = product.status === 'active';
          const brandMatch = productBrandId === targetBrandId;
          const matches = brandMatch && statusMatch;
          
          // Log detallado para productos que no coinciden
          if (!brandMatch && (product.brand || product.brandId)) {
            console.log(`  ⚠️ Producto "${product.name}":`);
            console.log(`     - brand del producto: "${productBrandId}" (tipo: ${typeof productBrandId})`);
            console.log(`     - brand buscado: "${targetBrandId}" (tipo: ${typeof targetBrandId})`);
            console.log(`     - ¿Coinciden?: ${brandMatch}`);
            console.log(`     - status: "${product.status}" (¿activo?: ${statusMatch})`);
          }
          
          return matches;
        });
        
        console.log(`✅ Productos encontrados para brand "${brandId}":`, filtered.length);
        if (filtered.length > 0) {
          console.log('📋 Productos encontrados:');
          filtered.forEach((p: any, index: number) => {
            console.log(`  ${index + 1}. ID: ${p.id}, Nombre: "${p.name}", brand: "${p.brand}", brandId: "${p.brandId}"`);
          });
        } else {
          console.log('⚠️ No se encontraron productos para esta marca');
          console.log(`   Buscando brand ID: "${brandId}"`);
          console.log(`   Productos disponibles: ${allProducts.length}`);
          // Mostrar todos los brand IDs únicos disponibles
          const uniqueBrands = [...new Set(allProducts.map((p: any) => p.brand || p.brandId).filter(Boolean))];
          console.log(`   Brand IDs únicos en productos:`, uniqueBrands);
        }
        
        return filtered;
      }

      // Función para mostrar productos de una marca
      async function showProductsForBrand(brandId: string) {
        const brandsSection = document.getElementById('brands-section');
        const productsGrid = document.getElementById('products-grid');
        const loadingState = document.getElementById('loading-state');
        const emptyState = document.getElementById('empty-state');
        const backToBrandsSection = document.getElementById('back-to-brands-section');
        
        if (!productsGrid) return;

        // Mostrar loading state mientras se cargan los productos
        if (loadingState && !productsCache.has(brandId)) {
          loadingState.classList.remove('hidden');
        }

        // Cargar productos bajo demanda
        const brandProducts = await loadProductsForBrand(brandId);

        // Ocultar loading state
        if (loadingState) loadingState.classList.add('hidden');

        console.log(`📦 Productos de la marca ${brandId}:`, brandProducts);
        console.log(`📊 Total de productos: ${brandProducts.length}`);

        // Ocultar marcas (flujo normal y rejilla de ofertas) y mostrar productos
        if (brandsSection) brandsSection.classList.add('hidden');
        document.getElementById('discount-brands-section')?.classList.add('hidden');
        document.getElementById('discount-products-section')?.classList.add('hidden');
        if (loadingState) loadingState.classList.add('hidden');
        
        // Mostrar barra de resultados (contador)
        if (backToBrandsSection) backToBrandsSection.classList.remove('hidden');
        // En header: ocultar "Volver a categorías", mostrar "Volver a marcas"
        document.getElementById('back-to-categories-btn')?.classList.add('hidden');
        document.getElementById('back-to-brands-btn')?.classList.remove('hidden');

        if (brandProducts.length === 0) {
          // Mostrar empty state
          productsGrid.style.display = 'none';
          if (emptyState) emptyState.classList.remove('hidden');
          return;
        }

        // Ocultar empty state
        if (emptyState) emptyState.classList.add('hidden');

        document.getElementById('main-content')?.classList.add('view-products');

        // Renderizar productos
        renderProducts(brandProducts);
        filteredProducts = brandProducts.slice();

        // Scroll suave a los productos
        productsGrid.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        if (discountFilterMode) {
          pushProductsFlowHistory(productsFlowHistoryState('products', { brandId, source: 'discount' }));
        } else if (currentCategoryId) {
          pushProductsFlowHistory(
            productsFlowHistoryState('products', { brandId, categoryId: currentCategoryId })
          );
        }
      }

      // Función para volver a categorías
      function showCategories() {
        if (discountFilterMode) {
          showDiscountBrandsView();
          return;
        }
        const categoriesSection = document.getElementById('categories-section');
        const brandsSection = document.getElementById('brands-section');
        const emptyState = document.getElementById('empty-state');
        
        if (categoriesSection) categoriesSection.classList.remove('hidden');
        if (brandsSection) brandsSection.classList.add('hidden');
        if (emptyState) emptyState.classList.add('hidden');
        document.getElementById('main-content')?.classList.remove('view-products');
        // Ocultar enlaces "Volver" del header
        document.getElementById('back-to-categories-btn')?.classList.add('hidden');
        document.getElementById('back-to-brands-btn')?.classList.add('hidden');
        
        // Scroll suave a la sección de categorías
        categoriesSection?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      // Función para volver a marcas
      function showBrands(categoryId?: string) {
        const categoriesSection = document.getElementById('categories-section');
        const brandsSection = document.getElementById('brands-section');
        const productsGrid = document.getElementById('products-grid');
        const backToBrandsSection = document.getElementById('back-to-brands-section');
        const emptyState = document.getElementById('empty-state');
        
        if (categoriesSection) categoriesSection.classList.add('hidden');
        if (brandsSection) brandsSection.classList.remove('hidden');
        if (productsGrid) productsGrid.style.display = 'none';
        if (backToBrandsSection) backToBrandsSection.classList.add('hidden');
        if (emptyState) emptyState.classList.add('hidden');
        // En header: mostrar "Volver a categorías", ocultar "Volver a marcas"
        document.getElementById('back-to-categories-btn')?.classList.remove('hidden');
        document.getElementById('back-to-brands-btn')?.classList.add('hidden');
        document.getElementById('main-content')?.classList.remove('view-products');

        // Si se proporciona categoryId, mostrar marcas de esa categoría
        if (categoryId) {
          showBrandsForCategory(categoryId);
        }
        
        // Scroll suave a la sección de marcas
        brandsSection?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

