      // Función para renderizar todos los productos
      
      // Función para mostrar notificación (declarada antes de su uso)
      const showNotification = (message: string, type: 'success' | 'info' = 'success') => {
        // Remover notificación anterior si existe
        const existingNotification = document.getElementById('favorite-notification');
        if (existingNotification) {
          existingNotification.remove();
        }

        const notification = document.createElement('div');
        notification.id = 'favorite-notification';
        notification.className = `fixed top-4 right-4 z-50 px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 ${
          type === 'success' ? 'bg-green-500 text-white' : 'bg-blue-500 text-white'
        }`;
        notification.style.animation = 'slideInRight 0.3s ease-out';
        
        notification.innerHTML = `
          <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-semibold text-sm md:text-base">${message}</span>
        `;
        
        document.body.appendChild(notification);
        
        // Remover después de 3 segundos
        setTimeout(() => {
          notification.style.animation = 'slideOutRight 0.3s ease-out';
          setTimeout(() => {
            if (notification.parentNode) {
              notification.remove();
            }
          }, 300);
        }, 3000);
      };

      // Función para actualizar el estado visual del botón de favoritos
      function updateFavoriteButton(button: Element, isFavorite: boolean) {
        const svg = button.querySelector('.favorite-icon') as SVGElement;
        if (!svg) {
          console.warn('No se encontró el SVG con clase favorite-icon');
          return;
        }
        
        const btn = button as HTMLElement;
        btn.setAttribute('data-is-favorite', String(isFavorite));
        btn.setAttribute('aria-label', isFavorite ? 'Quitar de favoritos' : 'Agregar a favoritos');
        
        if (isFavorite) {
          svg.setAttribute('fill', 'currentColor');
          svg.classList.remove('text-red-500');
          svg.classList.add('text-red-600');
        } else {
          svg.setAttribute('fill', 'none');
          svg.classList.remove('text-red-600');
          svg.classList.add('text-red-500');
        }
      }

      // Cargar favoritos del usuario
      async function loadUserFavorites() {
        try {
          let userId: string | null = localStorage.getItem('userId');
          if (!userId && typeof window !== 'undefined' && (window as any).currentUserId) {
            userId = (window as any).currentUserId;
          }

          if (!userId) {
            userFavorites = [];
            return;
          }

          const { getUserFavorites } = await import('../lib/db/favorites');
          const favoritesResult = await getUserFavorites(userId);
          
          if (favoritesResult.data && favoritesResult.data.productIds) {
            userFavorites = favoritesResult.data.productIds;
            // Actualizar estado visual de todos los botones de favoritos
            document.querySelectorAll('.favorite-btn').forEach(btn => {
              const productId = btn.getAttribute('data-product-id');
              if (productId && userFavorites.includes(productId)) {
                updateFavoriteButton(btn, true);
              }
            });
          }
        } catch (error) {
          console.warn('Error al cargar favoritos:', error);
          userFavorites = [];
        }
      }

      function renderProducts(products: any[]) {
        const grid = document.getElementById('products-grid');
        const loadingState = document.getElementById('loading-state');
        const emptyState = document.getElementById('empty-state');

        if (!grid) return;

        // Ocultar loading
        if (loadingState) loadingState.classList.add('hidden');

        if (products.length === 0) {
          grid.style.display = 'none';
          const mainView = document.getElementById('main-content');
          const inProductView = mainView?.classList.contains('view-products') === true;
          if (emptyState) {
            if (inProductView && allProducts.length > 0) {
              emptyState.classList.remove('hidden');
            } else {
              emptyState.classList.add('hidden');
            }
          }
          return;
        }

        // Mostrar grid y ocultar empty state (siempre vista cuadrícula)
        grid.style.display = 'grid';
        grid.classList.remove('list-view');
        if (emptyState) emptyState.classList.add('hidden');

        // Renderizar productos
        grid.innerHTML = products.map(product => renderProduct(product)).join('');

        // Actualizar estado visual de botones de favoritos después de renderizar
        document.querySelectorAll('.favorite-btn').forEach(btn => {
          const productId = btn.getAttribute('data-product-id');
          if (productId && userFavorites.includes(productId)) {
            updateFavoriteButton(btn, true);
          }
        });

        // Agregar event listeners a los botones de favoritos usando delegación de eventos
        // Esto evita problemas con múltiples listeners y elementos que se recrean
        const productsGrid = document.getElementById('products-grid');
        if (productsGrid) {
          // Usar delegación de eventos en el contenedor
          productsGrid.addEventListener('click', async (e) => {
            const target = e.target as HTMLElement;
            // Buscar el botón de favoritos o su padre
            const favoriteBtn = target.closest('.favorite-btn') as HTMLElement;
            
            if (!favoriteBtn) return;
            
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();
            
            const productId = favoriteBtn.getAttribute('data-product-id');
            if (!productId) {
              console.warn('No se encontró productId en el botón de favoritos');
              return;
            }

            console.log('Botón de favoritos clickeado, productId:', productId);

            // Obtener userId
            let userId: string | null = localStorage.getItem('userId');
            if (!userId && typeof window !== 'undefined' && (window as any).currentUserId) {
              userId = (window as any).currentUserId;
            }

            if (!userId) {
              const go = await showConfirmDialog({
                title: 'Iniciar sesión',
                message: 'Debes iniciar sesión para agregar productos a favoritos. ¿Deseas ir al login?',
                confirmLabel: 'Ir al login',
                cancelLabel: 'Cancelar',
                confirmVariant: 'primary',
              });
              if (go) {
                window.location.href = '/login?redirect=' + encodeURIComponent(window.location.pathname);
              }
              return;
            }

            try {
              console.log('Gestionando favorito, userId:', userId, 'productId:', productId);
              const { isFavorite, addToFavorites, removeFromFavorites } = await import('../lib/db/favorites');
              const isFav = await isFavorite(userId, productId);
              
              console.log('¿Está en favoritos?', isFav);
              
              if (isFav) {
                // Quitar de favoritos
                const result = await removeFromFavorites(userId, productId);
                if (result.success) {
                  updateFavoriteButton(favoriteBtn, false);
                  userFavorites = userFavorites.filter(id => id !== productId);
                  console.log('Producto quitado de favoritos');
                  showNotification('Producto quitado de favoritos', 'info');
                } else {
                  console.error('Error al quitar de favoritos:', result.error);
                  showNotification('Error al quitar de favoritos', 'info');
                }
              } else {
                // Agregar a favoritos
                const result = await addToFavorites(userId, productId);
                if (result.success) {
                  updateFavoriteButton(favoriteBtn, true);
                  if (!userFavorites.includes(productId)) {
                    userFavorites.push(productId);
                  }
                  console.log('Producto agregado a favoritos');
                  showNotification('Producto agregado a favoritos exitosamente', 'success');
                } else {
                  console.error('Error al agregar a favoritos:', result.error);
                  showNotification('Error al agregar a favoritos', 'info');
                }
              }
            } catch (error) {
              console.error('Error al gestionar favoritos:', error);
              showToast('Error al gestionar favoritos. Por favor, intenta nuevamente.', 'error');
            }
          }, true); // Usar capture phase para capturar antes que otros listeners
        }

        // Agregar event listeners a los controles de cantidad
        document.querySelectorAll('.quantity-increase-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const productId = btn.getAttribute('data-product-id');
            if (productId) {
              const input = document.querySelector(`.quantity-input[data-product-id="${productId}"]`) as HTMLInputElement;
              if (input) {
                const currentValue = parseInt(input.value) || 1;
                input.value = (currentValue + 1).toString();
                syncCardQuantityToCartIfInCart(productId);
              }
            }
          });
        });

        document.querySelectorAll('.quantity-decrease-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const productId = btn.getAttribute('data-product-id');
            if (productId) {
              const input = document.querySelector(`.quantity-input[data-product-id="${productId}"]`) as HTMLInputElement;
              if (input) {
                const currentValue = parseInt(input.value) || 1;
                if (currentValue > 1) {
                  input.value = (currentValue - 1).toString();
                }
                syncCardQuantityToCartIfInCart(productId);
              }
            }
          });
        });

        // Agregar event listeners a los botones "Agregar al Carrito" de las tarjetas
        document.querySelectorAll('.add-to-cart-card-btn').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            e.preventDefault();
            const button = btn as HTMLButtonElement;
            const productId = button.getAttribute('data-product-id');
            if (productId) {
              const input = document.querySelector(`.quantity-input[data-product-id="${productId}"]`) as HTMLInputElement;
              const quantity = input ? parseInt(input.value) || 1 : 1;
              const product = allProducts.find(p => String(p.id) === String(productId));
              
              if (product) {
                // Obtener nombre de la marca
                let brandName: string | undefined;
                if (product.brand) {
                  const brand = allBrandsData.find((b: any) => String(b.id) === String(product.brand));
                  brandName = brand?.name;
                }
                
                // Feedback visual
                const originalText = button.innerHTML;
                button.innerHTML = `
                  <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                  </svg>
                  <span>Agregando...</span>
                `;
                button.disabled = true;
                
                // Usar la función addToCart del Header
                const addToCartFn = (window as any).addToCart;
                if (addToCartFn && typeof addToCartFn === 'function') {
                  const success = addToCartFn({
                    id: String(product.id),
                    name: product.name,
                    price: product.price,
                    image: product.image || '',
                    brandName: brandName,
                    stock: product.stock
                  }, quantity);
                  
                  if (success) {
                    button.innerHTML = `
                      <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span>Agregado</span>
                    `;
                    button.classList.remove('bg-[#5d3fbb]', 'hover:bg-[#6d4fcc]');
                    button.classList.add('bg-green-500', 'hover:bg-green-600');
                    
                    setTimeout(() => {
                      button.innerHTML = originalText;
                      button.classList.remove('bg-green-500', 'hover:bg-green-600');
                      button.classList.add('bg-[#5d3fbb]', 'hover:bg-[#6d4fcc]');
                      button.disabled = false;
                    }, 1500);
                  } else {
                    // Error (stock insuficiente, etc.)
                    button.innerHTML = originalText;
                    button.disabled = false;
                  }
                } else {
                  // Fallback si no está disponible la función
                  console.warn('Función addToCart no disponible');
                  button.innerHTML = originalText;
                  button.disabled = false;
                }
              }
            }
          });
        });
      }

      // Función para filtrar productos
      function filterProducts() {
        const mainView = document.getElementById('main-content');
        const inProductView = mainView?.classList.contains('view-products') === true;
        if (allProducts.length === 0 && !inProductView) {
          const es = document.getElementById('empty-state');
          if (es) es.classList.add('hidden');
          updateActiveFiltersChips();
          return;
        }

        let products = [...allProducts];

        // Búsqueda por texto (nombre, marca, descripción)
        if (searchQuery.trim()) {
          const query = searchQuery.toLowerCase().trim();
          products = products.filter(p => {
            const name = (p.name || '').toLowerCase();
            const brandId = (p.brand || '').toLowerCase();
            const brandName = (p.brandName || '').toLowerCase();
            const description = (p.description || '').toLowerCase();
            return (
              name.includes(query) ||
              brandId.includes(query) ||
              brandName.includes(query) ||
              description.includes(query)
            );
          });
        }

        // Filtro por pet (?pet=dog|cat) — slug consistente con categoría Firestore
        if (petFilter !== 'all') {
          products = products.filter(p => getProductPetSlug(p) === petFilter);
        }

        // Filtro por tipo (discount/new)
        if (filterType === 'discount') {
          products = products.filter(p => (p.discount || 0) > 0);
        } else if (filterType === 'new') {
          // Simular productos nuevos (últimos 5)
          products = products.slice(-5);
        }

        // Filtros del sidebar: solo #desktop-filters-container (el drawer móvil clona IDs y rompe querySelector global)
        const desktopFc = document.getElementById('desktop-filters-container');
        if (desktopFc) {
          const types = getCheckedFilterValues(desktopFc, 'product-type');
          if (types.length > 0) {
            products = products.filter((p) => types.includes(effectiveProductType(p)));
          }

          const stages = getCheckedFilterValues(desktopFc, 'life-stage');
          if (stages.length > 0) {
            products = products.filter((p) => productMatchesLifeStageFilter(p, stages));
          }

          const sizes = getCheckedFilterValues(desktopFc, 'breed-size');
          if (sizes.length > 0) {
            products = products.filter((p) => productMatchesBreedSizeFilter(p, sizes));
          }

          const priceRanges = getCheckedFilterValues(desktopFc, 'price');
          if (priceRanges.length > 0) {
            products = products.filter((p) => {
              return priceRanges.some((range) => {
                if (range === '300+') return p.price >= 300;
                const [min, max] = range.split('-').map(Number);
                return p.price >= min && p.price < max;
              });
            });
          }
        }

        filteredProducts = products;
        updateActiveFiltersChips();

        const productsGridEl = document.getElementById('products-grid');
        const gridVisible = productsGridEl && productsGridEl.style.display !== 'none';

        if (!inProductView && !gridVisible) {
          const es = document.getElementById('empty-state');
          if (es) es.classList.add('hidden');
          return;
        }

        renderProducts(filteredProducts);
      }

      // Función para ordenar productos
      function sortProducts(sortValue: string) {
        const mainView = document.getElementById('main-content');
        if (!mainView?.classList.contains('view-products')) return;

        const sorted = [...filteredProducts];

        switch(sortValue) {
          case 'price-low':
            sorted.sort((a, b) => a.price - b.price);
            break;
          case 'price-high':
            sorted.sort((a, b) => b.price - a.price);
            break;
          case 'discount':
            sorted.sort((a, b) => (b.discount || 0) - (a.discount || 0));
            break;
          default:
            // Mantener orden original
            break;
        }

        renderProducts(sorted);
      }

      // Cargar productos desde Firebase (TODO se ejecuta en el CLIENTE)
      async function loadProducts() {
        try {
          // Importar funciones de Firebase (client-side)
          // Todas estas funciones se ejecutan en el navegador y se conectan directamente a Firestore
          // @ts-ignore
          const { getProducts } = await import('../lib/db/products');
          // @ts-ignore
          const { getCategoriesByAnimalType } = await import('../lib/db/categories');
          // @ts-ignore
          const { getBrands } = await import('../lib/db/brands');

          // Mapear parámetro de URL a animalType
          let animalType: 'Perro' | 'Gato' | null = null;
          if (petFilter === 'dog') {
            animalType = 'Perro';
          } else if (petFilter === 'cat') {
            animalType = 'Gato';
          }

          console.log('🔍 Parámetro de URL (petFilter):', petFilter);
          console.log('🐾 Tipo de animal a filtrar:', animalType || 'Todos');

          // Obtener todas las categorías y filtrar en el cliente (evita problemas de índices)
          console.log('📂 Obteniendo todas las categorías...');
          const { getCategories } = await import('../lib/db/categories');
          const allCategoriesResult = await getCategories();
          
          console.log('📋 Todas las categorías sin filtrar:', allCategoriesResult.data || []);
          console.log('📊 Total de categorías sin filtrar:', allCategoriesResult.data?.length || 0);
          
          // Mostrar detalles de cada categoría para debug
          if (allCategoriesResult.data && allCategoriesResult.data.length > 0) {
            console.log('🔍 Detalles de categorías:');
            allCategoriesResult.data.forEach((c: any, index: number) => {
              console.log(`  ${index + 1}. ID: ${c.id}, Nombre: ${c.name}, animalType: "${c.animalType}", status: "${c.status}"`);
            });
          }
          
          // Filtrar categorías en el cliente según el tipo de animal
          let categoriesResult;
          if (animalType) {
            console.log(`🔍 Filtrando categorías para: "${animalType}" (tipo exacto)`);
            if (allCategoriesResult.data) {
              const filtered = allCategoriesResult.data.filter((c: any) => {
                const matches = c.animalType === animalType && c.status === 'Activo';
                if (!matches && c.animalType === animalType) {
                  console.log(`  ⚠️ Categoría "${c.name}" tiene animalType="${c.animalType}" pero status="${c.status}"`);
                }
                return matches;
              });
              categoriesResult = { data: filtered };
              console.log(`✅ Categorías filtradas encontradas: ${filtered.length}`);
            } else {
              categoriesResult = { data: [] };
            }
          } else {
            // Si no hay filtro, solo filtrar por activas
            if (allCategoriesResult.data) {
              categoriesResult = {
                data: allCategoriesResult.data.filter((c: any) => c.status === 'Activo')
              };
            } else {
              categoriesResult = { data: [] };
            }
          }

          console.log('✅ Categorías obtenidas (después de filtrar):', categoriesResult.data || []);
          console.log('📊 Total de categorías filtradas:', categoriesResult.data?.length || 0);

          // Guardar todas las categorías para referencia
          allCategoriesData = categoriesResult.data || [];
          
          // Optimizar estructura de datos: crear Maps para búsquedas O(1)
          categoryMap.clear();
          allCategoriesData.forEach((category: any) => {
            categoryMap.set(category.id, category);
            // Inicializar contadores
            categoryBrandCounts.set(category.id, 0);
          });

          let discountOffersProductCount = -1;
          if (discountFilterMode) {
            discountOffersProductCount = await loadDiscountOffersFromFirestore();
            categoriesResult = { data: [] };
          }
          
          console.log('✅ Estructura de datos optimizada: Maps creados para búsquedas O(1)');
          
          // Cachear categorías en Service Worker para acceso offline
          if (typeof window !== 'undefined' && (window as any).cacheData) {
            (window as any).cacheData('categories', allCategoriesData);
          }

          // Renderizar categorías y ocultar loading state
          const loadingState = document.getElementById('loading-state');
          const productsGrid = document.getElementById('products-grid');
          
          if (discountFilterMode) {
            if (loadingState) loadingState.classList.add('hidden');
            document.getElementById('categories-section')?.classList.add('hidden');
            const emptyState = document.getElementById('empty-state');
            if (emptyState) {
              if (discountOffersProductCount === 0) {
                emptyState.classList.remove('hidden');
              } else {
                emptyState.classList.add('hidden');
              }
            }
          } else if (categoriesResult.data && categoriesResult.data.length > 0) {
            renderCategories(categoriesResult.data);
            if (loadingState) loadingState.classList.add('hidden');
          } else {
            if (loadingState) loadingState.classList.add('hidden');
            const emptyState = document.getElementById('empty-state');
            if (emptyState) emptyState.classList.remove('hidden');
          }
          
          // Asegurar que el grid de productos esté oculto al inicio
          if (productsGrid) {
            productsGrid.style.display = 'none';
          }

          // NO cargar marcas ni productos al inicio - se cargarán bajo demanda
          console.log('✅ Carga bajo demanda activada: marcas y productos se cargarán cuando se necesiten');

          if (discountFilterMode) {
            replaceProductsFlowHistory(productsFlowHistoryState('discount-brands'));
          } else {
            replaceProductsFlowHistory(productsFlowHistoryState('categories'));
          }
          
          // Ocultar loader y mostrar contenido
          hidePageLoader();
        } catch (error) {
          console.error('❌ Error cargando productos:', error);
          const loadingState = document.getElementById('loading-state');
          if (loadingState) {
            loadingState.innerHTML = `
              <div class="text-center py-16">
                <svg class="w-16 h-16 mx-auto text-red-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p class="text-red-600 text-lg">Error al cargar los productos. Por favor, recarga la página.</p>
              </div>
            `;
          }
          // Ocultar loader incluso si hay error
          hidePageLoader();
        }
      }

      // Un solo patrón: clase .ready + fade-out del loader (sin reflow ni ramas móvil/desktop)
      function hidePageLoader() {
        const pageLoader = document.getElementById('page-loader');
        const navigationLoader = document.getElementById('navigation-loader');
        const mainContent = document.getElementById('main-content');

        if (navigationLoader) {
          navigationLoader.style.display = 'none';
          navigationLoader.remove();
        }
        if (mainContent) mainContent.classList.add('ready');
        if (pageLoader) {
          setTimeout(() => {
            pageLoader.style.opacity = '0';
            setTimeout(() => { pageLoader.style.display = 'none'; }, 300);
          }, 120);
        }
      }

      // Manejar resize para ocultar/mostrar sidebar desktop correctamente
      let resizeTimeout: NodeJS.Timeout;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
          const desktopSidebar = document.getElementById('desktop-filters-sidebar');
          if (desktopSidebar) {
            if (window.innerWidth >= 1024) {
              desktopSidebar.style.display = 'block';
            } else {
              desktopSidebar.style.display = 'none';
            }
          }
        }, 100);
      });

    // Toggle filtros
    const filterButtons = [
      { btn: 'price-filter-btn', content: 'price-filter-content', arrow: 'price-arrow' },
      { btn: 'life-stage-filter-btn', content: 'life-stage-filter-content', arrow: 'life-stage-arrow' },
      { btn: 'breed-size-filter-btn', content: 'breed-size-filter-content', arrow: 'breed-size-arrow' },
      { btn: 'type-filter-btn', content: 'type-filter-content', arrow: 'type-arrow' }
    ];

    filterButtons.forEach(({ btn, content, arrow }) => {
      const button = document.getElementById(btn);
      const filterContent = document.getElementById(content);
      const arrowIcon = document.getElementById(arrow);

      button?.addEventListener('click', () => {
        const isHidden = filterContent?.classList.contains('hidden');
        if (isHidden) {
          filterContent?.classList.remove('hidden');
          arrowIcon?.classList.add('rotate-180');
        } else {
          filterContent?.classList.add('hidden');
          arrowIcon?.classList.remove('rotate-180');
        }
      });
    });

      // Búsqueda desplegable en móvil
      const mobileSearchToggle = document.getElementById('mobile-search-toggle');
      const searchBarContainer = document.getElementById('search-bar-container');
      mobileSearchToggle?.addEventListener('click', () => {
        if (!searchBarContainer) return;
        const isOpen = searchBarContainer.classList.contains('mobile-search-open');
        if (isOpen) {
          searchBarContainer.classList.remove('mobile-search-open');
        } else {
          searchBarContainer.classList.add('mobile-search-open');
          setTimeout(() => (document.getElementById('search-input') as HTMLInputElement)?.focus(), 100);
        }
      });

      // Funcionalidad del Drawer de Filtros Móvil
      const mobileFiltersBtn = document.getElementById('mobile-filters-btn');
      const mobileFiltersDrawer = document.getElementById('mobile-filters-drawer');
      const mobileFiltersOverlay = document.getElementById('mobile-filters-overlay');
      const closeMobileFiltersBtn = document.getElementById('close-mobile-filters-btn');
      const mobileFiltersContent = document.getElementById('mobile-filters-content');
      const applyFiltersBtn = document.getElementById('apply-filters-btn');
      const clearFiltersBtn = document.getElementById('clear-filters-btn');
      const activeFiltersCount = document.getElementById('active-filters-count');

      // Copiar contenido de filtros al drawer móvil
      function copyFiltersToMobile() {
        if (!mobileFiltersContent) return;
        const desktopFiltersContainer = document.getElementById('desktop-filters-container');
        if (desktopFiltersContainer) {
          // Clonar el contenido de los filtros (deep clone para no afectar el original)
          const filtersClone = desktopFiltersContainer.cloneNode(true) as HTMLElement;
          const header = filtersClone.querySelector('#desktop-filters-header');
          if (header) header.remove();
          
          mobileFiltersContent.innerHTML = filtersClone.innerHTML;
          
          // Sincronizar checkboxes existentes
          syncCheckboxes();
          
          // Re-inicializar los event listeners de los filtros móviles
          initializeMobileFilters();
        }
      }

      function syncCheckboxes() {
        if (!mobileFiltersContent) return;

        const desktopFiltersContainer = document.getElementById('desktop-filters-container');
        if (!desktopFiltersContainer) return;

        const desktopCheckboxes = desktopFiltersContainer.querySelectorAll('input[type="checkbox"]');
        const mobileCheckboxes = mobileFiltersContent.querySelectorAll('input[type="checkbox"]');

        desktopCheckboxes.forEach((desktopCb) => {
          const desktopValue = (desktopCb as HTMLInputElement).value;
          const mobileCb = Array.from(mobileCheckboxes).find(
            (cb) => (cb as HTMLInputElement).value === desktopValue
          ) as HTMLInputElement | undefined;

          if (mobileCb) {
            mobileCb.checked = (desktopCb as HTMLInputElement).checked;
          }
        });
      }

      function initializeMobileFilters() {
        if (!mobileFiltersContent) return;
        
        // Toggle filtros en móvil (buscar dentro del drawer)
        const filterButtons = [
          { btn: 'price-filter-btn', content: 'price-filter-content', arrow: 'price-arrow' },
          { btn: 'life-stage-filter-btn', content: 'life-stage-filter-content', arrow: 'life-stage-arrow' },
          { btn: 'breed-size-filter-btn', content: 'breed-size-filter-content', arrow: 'breed-size-arrow' },
          { btn: 'type-filter-btn', content: 'type-filter-content', arrow: 'type-arrow' }
        ];

        filterButtons.forEach(({ btn, content, arrow }) => {
          const button = mobileFiltersContent.querySelector(`button#${btn}`);
          const filterContent = mobileFiltersContent.querySelector(`div#${content}`);
          const arrowIcon = mobileFiltersContent.querySelector(`svg#${arrow}`);

          if (button && filterContent) {
            // Remover listeners anteriores si existen
            const newButton = button.cloneNode(true) as HTMLButtonElement;
            button.parentNode?.replaceChild(newButton, button);
            
            newButton.addEventListener('click', () => {
              const isHidden = filterContent.classList.contains('hidden');
              if (isHidden) {
                filterContent.classList.remove('hidden');
                if (arrowIcon) arrowIcon.classList.add('rotate-180');
              } else {
                filterContent.classList.add('hidden');
                if (arrowIcon) arrowIcon.classList.remove('rotate-180');
              }
            });
          }
        });
      }

      function openMobileFilters() {
        copyFiltersToMobile();
        if (mobileFiltersDrawer) {
          mobileFiltersDrawer.classList.remove('translate-x-full');
          mobileFiltersDrawer.classList.add('translate-x-0');
        }
        if (mobileFiltersOverlay) {
          mobileFiltersOverlay.classList.remove('hidden');
          mobileFiltersOverlay.style.display = 'block';
        }
        document.body.style.overflow = 'hidden';
      }

      function closeMobileFilters() {
        if (mobileFiltersDrawer) {
          mobileFiltersDrawer.classList.remove('translate-x-0');
          mobileFiltersDrawer.classList.add('translate-x-full');
        }
        if (mobileFiltersOverlay) {
          mobileFiltersOverlay.classList.add('hidden');
          mobileFiltersOverlay.style.display = 'none';
        }
        document.body.style.overflow = '';
      }

      function updateActiveFiltersCount() {
        if (!activeFiltersCount) return;
        // Solo contar checkboxes del sidebar desktop (evitar duplicados)
        const desktopFiltersContainer = document.getElementById('desktop-filters-container');
        if (!desktopFiltersContainer) return;
        
        const allCheckboxes = desktopFiltersContainer.querySelectorAll('input[type="checkbox"]:checked');
        const count = allCheckboxes.length;
        if (count > 0) {
          activeFiltersCount.textContent = count.toString();
          activeFiltersCount.style.display = 'flex';
          activeFiltersCount.classList.remove('hidden');
        } else {
          activeFiltersCount.style.display = 'none';
          activeFiltersCount.classList.add('hidden');
        }
      }

      // Función para obtener etiquetas de filtros
      function getFilterLabel(type: string, value: string): string {
        const labels: { [key: string]: { [key: string]: string } } = {
          'type': {
            'food': 'Alimento',
            'toy': 'Juguetes',
            'cleaning': 'Limpieza',
            'accessory': 'Accesorios'
          },
          'life-stage': {
            'cachorro': 'Cachorro',
            'adulto': 'Adulto',
            'senior': 'Senior'
          },
          'breed-size': {
            'pequeña': 'Pequeña',
            'mediana': 'Mediana',
            'grande': 'Grande',
            'todos': 'Todos los tamaños'
          },
          'price': {
            '0-100': 'Bs. 0 - 100',
            '100-200': 'Bs. 100 - 200',
            '200-300': 'Bs. 200 - 300',
            '300+': 'Bs. 300+'
          }
        };
        return labels[type]?.[value] || value;
      }

      // Función para actualizar chips de filtros activos
      function updateActiveFiltersChips() {
        const chipsContainer = document.getElementById('active-filters-chips');
        if (!chipsContainer) return;

        const desktopFiltersContainer = document.getElementById('desktop-filters-container');
        if (!desktopFiltersContainer) return;

        // Limpiar chips existentes
        chipsContainer.innerHTML = '';
        
        const chips: string[] = [];

        // Agregar chip de búsqueda si existe
        if (searchQuery.trim()) {
          chips.push(`
            <div class="filter-chip" data-filter-type="search" data-filter-value="${searchQuery}">
              <span class="filter-chip__label">🔍 "${searchQuery}"</span>
              <button type="button" class="filter-chip__close" aria-label="Eliminar búsqueda">
                <svg class="filter-chip__close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          `);
        }

        // Agregar chips de filtros checkboxes
        const filterTypes = [
          { selector: '[data-filter-panel="product-type"] input:checked', type: 'type', prefix: 'Tipo: ' },
          { selector: '[data-filter-panel="life-stage"] input:checked', type: 'life-stage', prefix: 'Etapa: ' },
          { selector: '[data-filter-panel="breed-size"] input:checked', type: 'breed-size', prefix: 'Tamaño: ' },
          { selector: '[data-filter-panel="price"] input:checked', type: 'price', prefix: 'Precio: ' }
        ];

        filterTypes.forEach(({ selector, type, prefix }) => {
          const checkboxes = desktopFiltersContainer.querySelectorAll(selector);
          checkboxes.forEach((cb: any) => {
            const value = cb.value;
            const label = getFilterLabel(type, value);
            chips.push(`
              <div class="filter-chip" data-filter-type="${type}" data-filter-value="${value}">
                <span class="filter-chip__label">${prefix}${label}</span>
                <button type="button" class="filter-chip__close" aria-label="Eliminar filtro">
                  <svg class="filter-chip__close-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                  </svg>
                </button>
              </div>
            `);
          });
        });

        // Renderizar chips
        if (chips.length > 0) {
          chipsContainer.innerHTML = `
            <div class="active-filters-chips__head flex items-baseline gap-1.5 mb-1.5 w-full sm:mb-2 sm:gap-2">
              <span class="text-[11px] font-medium uppercase tracking-wide text-gray-500 sm:text-xs sm:normal-case sm:tracking-normal sm:font-semibold sm:text-gray-700">Activos</span>
            </div>
            <div class="active-filters-chips__row flex flex-wrap items-center gap-1.5 w-full sm:gap-2">
              ${chips.join('')}
            </div>
          `;
          chipsContainer.classList.remove('hidden');
          chipsContainer.classList.add('flex', 'flex-col', 'gap-1', 'sm:gap-1.5');
          chipsContainer.style.display = 'flex';
          
          // Agregar event listeners a los botones de eliminar
          chipsContainer.querySelectorAll('.filter-chip button').forEach(btn => {
            btn.addEventListener('click', (e) => {
              e.stopPropagation();
              const chip = (e.target as HTMLElement).closest('.filter-chip');
              if (chip) {
                const filterType = chip.getAttribute('data-filter-type');
                const filterValue = chip.getAttribute('data-filter-value');
                
                if (filterType === 'search') {
                  searchQuery = '';
                  const hs = document.getElementById('header-search-input') as HTMLInputElement | null;
                  const ms = document.getElementById('mobile-search-input') as HTMLInputElement | null;
                  const ls = document.getElementById('search-input') as HTMLInputElement | null;
                  if (hs) hs.value = '';
                  if (ms) ms.value = '';
                  if (ls) ls.value = '';
                  document.getElementById('header-clear-search-btn')?.classList.add('hidden');
                  document.getElementById('mobile-clear-search-btn')?.classList.add('hidden');
                  document.getElementById('clear-search-btn')?.classList.add('hidden');
                } else if (filterValue) {
                  const safeVal = CSS.escape(filterValue);
                  const checkbox = desktopFiltersContainer.querySelector(
                    `input[type="checkbox"][value="${safeVal}"]`
                  ) as HTMLInputElement;
                  if (checkbox) {
                    checkbox.checked = false;
                    const mobileCheckbox = document.querySelector(
                      `#mobile-filters-content input[type="checkbox"][value="${safeVal}"]`
                    ) as HTMLInputElement;
                    if (mobileCheckbox) mobileCheckbox.checked = false;
                  }
                }
                
                filterProducts();
                updateActiveFiltersCount();
                updateActiveFiltersChips();
              }
            });
          });
        } else {
          chipsContainer.classList.add('hidden');
          chipsContainer.classList.remove('flex', 'flex-col', 'gap-1', 'sm:gap-1.5');
          chipsContainer.style.display = 'none';
        }
      }

      function clearAllFilters() {
        const desktopBox = document.getElementById('desktop-filters-container');
        desktopBox?.querySelectorAll('input[type="checkbox"]').forEach((cb) => {
          (cb as HTMLInputElement).checked = false;
        });
        document.getElementById('mobile-filters-content')?.querySelectorAll('input[type="checkbox"]').forEach((cb) => {
          (cb as HTMLInputElement).checked = false;
        });
        // Limpiar búsqueda (header desktop / móvil)
        const searchInput =
          (document.getElementById('header-search-input') as HTMLInputElement) ||
          (document.getElementById('mobile-search-input') as HTMLInputElement) ||
          (document.getElementById('search-input') as HTMLInputElement);
        searchQuery = '';
        const hsClear = document.getElementById('header-search-input') as HTMLInputElement | null;
        const msClear = document.getElementById('mobile-search-input') as HTMLInputElement | null;
        const lsClear = document.getElementById('search-input') as HTMLInputElement | null;
        if (hsClear) hsClear.value = '';
        if (msClear) msClear.value = '';
        if (lsClear) lsClear.value = '';
        document.getElementById('header-clear-search-btn')?.classList.add('hidden');
        document.getElementById('mobile-clear-search-btn')?.classList.add('hidden');
        document.getElementById('clear-search-btn')?.classList.add('hidden');
        updateActiveFiltersCount();
        filterProducts();
        updateActiveFiltersChips();
        closeMobileFilters();
      }

      // Event listeners
      mobileFiltersBtn?.addEventListener('click', openMobileFilters);
      closeMobileFiltersBtn?.addEventListener('click', closeMobileFilters);

      mobileFiltersContent?.addEventListener('change', (e) => {
        const t = e.target as HTMLElement;
        if (!t.matches('input[type="checkbox"]')) return;
        const mobileCb = t as HTMLInputElement;
        const desktopFiltersContainer = document.getElementById('desktop-filters-container');
        const desktopCb = desktopFiltersContainer?.querySelector(
          `input[type="checkbox"][value="${CSS.escape(mobileCb.value)}"]`
        ) as HTMLInputElement | null;
        if (desktopCb) desktopCb.checked = mobileCb.checked;
        filterProducts();
        updateActiveFiltersChips();
        updateActiveFiltersCount();
      });
      applyFiltersBtn?.addEventListener('click', () => {
        // Sincronizar checkboxes de móvil a desktop antes de filtrar
        const desktopFiltersContainer = document.getElementById('desktop-filters-container');
        if (mobileFiltersContent && desktopFiltersContainer) {
          const mobileCheckboxes = mobileFiltersContent.querySelectorAll('input[type="checkbox"]');
          mobileCheckboxes.forEach((node) => {
            const mobileCb = node as HTMLInputElement;
            const desktopCb = desktopFiltersContainer.querySelector(
              `input[type="checkbox"][value="${CSS.escape(mobileCb.value)}"]`
            ) as HTMLInputElement | null;
            if (desktopCb) desktopCb.checked = mobileCb.checked;
          });
        }
        filterProducts();
        updateActiveFiltersCount();
        updateActiveFiltersChips();
        closeMobileFilters();
      });
      clearFiltersBtn?.addEventListener('click', clearAllFilters);

      // Botón de limpiar filtros en empty state
      const clearAllFiltersEmptyBtn = document.getElementById('clear-all-filters-empty');
      clearAllFiltersEmptyBtn?.addEventListener('click', clearAllFilters);

      if (mobileFiltersOverlay) {
        mobileFiltersOverlay.addEventListener('click', closeMobileFilters);
      }

      // Actualizar contador cuando cambien los filtros
      document.addEventListener('change', (e) => {
        if ((e.target as HTMLElement).matches('input[type="checkbox"]')) {
          updateActiveFiltersCount();
        }
      });

      // Ordenamiento
      const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
      const sortTriggerMobile = document.getElementById('sort-trigger-mobile');
      const sortDropdownMobile = document.getElementById('sort-dropdown-mobile');

      function applySort(value: string) {
        if (sortSelect) sortSelect.value = value;
        sortProducts(value);
      }

      sortSelect?.addEventListener('change', (e) => {
        const value = (e.target as HTMLSelectElement).value;
        sortProducts(value);
      });

      // Móvil: abrir/cerrar dropdown de ordenar (abre hacia la izquierda)
      sortTriggerMobile?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = sortDropdownMobile?.classList.toggle('hidden');
        sortTriggerMobile?.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      });

      sortDropdownMobile?.querySelectorAll('.sort-dropdown-option').forEach((btn) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const value = (btn as HTMLElement).getAttribute('data-value');
          if (value) {
            applySort(value);
            sortDropdownMobile?.classList.add('hidden');
            sortTriggerMobile?.setAttribute('aria-expanded', 'false');
          }
        });
      });

      // Cerrar dropdown al tocar fuera
      document.addEventListener('click', (e) => {
        if (sortDropdownMobile?.classList.contains('hidden')) return;
        const target = e.target as Node;
        if (sortDropdownMobile && !sortDropdownMobile.contains(target) && !sortTriggerMobile?.contains(target)) {
          sortDropdownMobile.classList.add('hidden');
          sortTriggerMobile?.setAttribute('aria-expanded', 'false');
        }
      });

    // Filtros desktop: delegación (los del drawer móvil se sincronizan arriba y no duplican listeners al clonar)
    document.getElementById('desktop-filters-container')?.addEventListener('change', (e) => {
      const t = e.target as HTMLElement;
      if (!t.matches('input[type="checkbox"]')) return;
      filterProducts();
      updateActiveFiltersChips();
    });

    // Búsqueda en tiempo real (Header desktop + móvil; mismo estado que filtros)
    const headerSearchEl = document.getElementById('header-search-input') as HTMLInputElement | null;
    const mobileSearchEl = document.getElementById('mobile-search-input') as HTMLInputElement | null;
    const legacySearchEl = document.getElementById('search-input') as HTMLInputElement | null;

    function syncSearchMirror(source: HTMLInputElement) {
      searchQuery = source.value || '';
      if (headerSearchEl && source !== headerSearchEl) headerSearchEl.value = searchQuery;
      if (mobileSearchEl && source !== mobileSearchEl) mobileSearchEl.value = searchQuery;
      if (legacySearchEl && source !== legacySearchEl) legacySearchEl.value = searchQuery;
    }

    function toggleClearButtons(hasText: boolean) {
      document.getElementById('header-clear-search-btn')?.classList.toggle('hidden', !hasText);
      document.getElementById('mobile-clear-search-btn')?.classList.toggle('hidden', !hasText);
      document.getElementById('clear-search-btn')?.classList.toggle('hidden', !hasText);
    }

    if (urlSearchQuery) {
      searchQuery = urlSearchQuery;
      if (headerSearchEl) headerSearchEl.value = urlSearchQuery;
      if (mobileSearchEl) mobileSearchEl.value = urlSearchQuery;
      if (legacySearchEl) legacySearchEl.value = urlSearchQuery;
      toggleClearButtons(true);
    }

    function handleSearch(ev: Event) {
      const source = ev.target as HTMLInputElement;
      if (searchTimeout) clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        syncSearchMirror(source);
        toggleClearButtons(!!searchQuery.trim());
        filterProducts();
        updateActiveFiltersChips();
      }, 300);
    }

    function onSearchKeydown(ev: KeyboardEvent) {
      if (ev.key !== 'Enter') return;
      ev.preventDefault();
      if (searchTimeout) clearTimeout(searchTimeout);
      syncSearchMirror(ev.target as HTMLInputElement);
      toggleClearButtons(!!searchQuery.trim());
      filterProducts();
      updateActiveFiltersChips();
    }

    [headerSearchEl, mobileSearchEl, legacySearchEl].forEach((el) => {
      if (!el) return;
      el.addEventListener('input', handleSearch);
      el.addEventListener('keydown', onSearchKeydown);
    });

    function clearAllSearchInputs() {
      searchQuery = '';
      headerSearchEl && (headerSearchEl.value = '');
      mobileSearchEl && (mobileSearchEl.value = '');
      legacySearchEl && (legacySearchEl.value = '');
      toggleClearButtons(false);
      filterProducts();
      updateActiveFiltersChips();
    }

    document.getElementById('header-clear-search-btn')?.addEventListener('click', clearAllSearchInputs);
    document.getElementById('mobile-clear-search-btn')?.addEventListener('click', clearAllSearchInputs);
    document.getElementById('clear-search-btn')?.addEventListener('click', clearAllSearchInputs);

      window.addEventListener('popstate', async (e) => {
        const st = e.state as { __ns?: string; screen?: string; categoryId?: string; brandId?: string; source?: string } | null;
        if (!st || st.__ns !== PRODUCTS_HISTORY_NS || !st.screen) return;

        productsFlowHistoryHandlingPop = true;
        try {
          switch (st.screen) {
            case 'categories':
              showCategories();
              break;
            case 'discount-brands':
              showDiscountBrandsView();
              break;
            case 'brands':
              if (st.categoryId) await showBrandsForCategory(st.categoryId);
              break;
            case 'products':
              if (st.brandId) await showProductsForBrand(st.brandId);
              break;
            default:
              break;
          }
        } finally {
          productsFlowHistoryHandlingPop = false;
        }
      });

      // Event listener para botón "Volver a categorías" (misma pila que el botón atrás del sistema)
      const backToCategoriesBtn = document.getElementById('back-to-categories-btn');
      backToCategoriesBtn?.addEventListener('click', (ev) => {
        ev.preventDefault();
        history.back();
      });

      // Event listener para botón "Volver a marcas"
      const backToBrandsBtn = document.getElementById('back-to-brands-btn');
      backToBrandsBtn?.addEventListener('click', (ev) => {
        ev.preventDefault();
        history.back();
      });

      // Inicializar
      loadProducts();
      // Cargar favoritos del usuario después de que se carguen los productos
      loadUserFavorites();
      
      // Inicializar contador de filtros activos
      updateActiveFiltersCount();
      
      // Inicializar chips de filtros (se actualizarán después de cargar productos)
      updateActiveFiltersChips();
    }
  </script>
</Layout>
